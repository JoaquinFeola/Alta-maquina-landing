---
import Container from './Container.astro';
import * as Icons from '@tabler/icons-react';

const { IconSun, IconMoon, IconMenu2 } = Icons;
---

<script>
  // Menu toggle
  const menuButton = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function toggleMenu() {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
  }

  menuButton?.addEventListener('click', toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    });
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const themeToggleMobile = document.getElementById('theme-toggle-mobile');

  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');

    if (isDark) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  }

  themeToggle?.addEventListener('click', toggleTheme);
  themeToggleMobile?.addEventListener('click', toggleTheme);

  // Header scroll effect - integrate with Hero when at top
  const header = document.getElementById('main-header');
  const scrollThreshold = 50;

  function handleScroll() {
    if (window.scrollY < scrollThreshold) {
      header?.classList.add('header-at-top');
      header?.classList.remove('header-scrolled');
    } else {
      header?.classList.remove('header-at-top');
      header?.classList.add('header-scrolled');
    }
  }

  // Initial check and listen for scroll
  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300
         header-at-top
         border-b-0
         [&_.nav-link]:text-gray-700 dark:[&_.nav-link]:text-white/80
         [&_.nav-link:hover]:text-blue-600 dark:[&_.nav-link:hover]:text-blue-400
         [&_.logo-text]:text-gray-800 dark:[&_.logo-text]:text-white
         [&_button]:text-gray-700 dark:[&_button]:text-white/90
         [&_button:hover]:text-gray-900 dark:[&_button:hover]:text-white
         [&_.mobile-menu-bg]:bg-transparent dark:[&_.mobile-menu-bg]:bg-transparent
         [&_.mobile-link]:text-gray-700 dark:[&_.mobile-link]:text-white/80
         [&_.mobile-link:hover]:text-blue-600 dark:[&_.mobile-link:hover]:text-blue-400"
>
  <Container>
    <nav class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
        <img src="/favicon.svg" alt="Alta Maquina" class="w-10 h-10 rounded-full object-cover" />
        <span class="ml-3 text-lg font-bold logo-text">Alta Maquina</span>
      </a>
      
      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        <li>
          <a href="#servicios" class="nav-link text-sm hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Servicios
          </a>
        </li>
        <li>
          <a href="#planes" class="nav-link text-sm hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Planes
          </a>
        </li>
        <li>
          <a href="#por-que-elegirnos" class="nav-link text-sm hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Nosotros
          </a>
        </li>
        <li>
          <a href="#contacto" class="nav-link text-sm hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Contacto
          </a>
        </li>
        <li>
          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            type="button"
            class="p-2 rounded-lg transition-all duration-200 focus:outline-none bg-white/50 dark:bg-white/10 hover:bg-white/80 dark:hover:bg-white/20 backdrop-blur-sm"
            aria-label="Cambiar tema"
          >
            <IconMoon className="w-5 h-5 theme-icon" />
            <IconSun className="w-5 h-5 theme-icon hidden dark:block" />
          </button>
        </li>
      </ul>

      <!-- Mobile Menu Button -->
      <button 
        id="menu-toggle" 
        type="button" 
        class="md:hidden p-2 focus:outline-none text-gray-700 dark:text-white"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <IconMenu2 className="w-6 h-6" />
      </button>
    </nav>
  </Container>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden mobile-menu-bg">
    <Container>
      <ul class="py-4 space-y-4">
        <li>
          <a href="#servicios" class="mobile-link block text-base hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Servicios
          </a>
        </li>
        <li>
          <a href="#planes" class="mobile-link block text-base hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Planes
          </a>
        </li>
        <li>
          <a href="#por-que-elegirnos" class="mobile-link block text-base hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Nosotros
          </a>
        </li>
        <li>
          <a href="#contacto" class="mobile-link block text-base hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            Contacto
          </a>
        </li>
        <li>
          <!-- Theme Toggle Button (Mobile) -->
          <button
            id="theme-toggle-mobile"
            type="button"
            class="p-2 rounded-lg transition-all duration-200 focus:outline-none bg-white/50 dark:bg-white/10 hover:bg-white/80 dark:hover:bg-white/20 backdrop-blur-sm"
            aria-label="Cambiar tema"
          >
            <IconMoon className="w-5 h-5 theme-icon" />
            <IconSun className="w-5 h-5 theme-icon hidden dark:block" />
          </button>
        </li>
      </ul>
    </Container>
  </div>
</header>

<style>
  /* At top state - transparent background with adaptive text colors */
  .header-at-top {
    @apply bg-transparent border-b-0;
  }

  .header-at-top .nav-link {
    @apply text-gray-700 dark:text-white/80;
  }

  .header-at-top .nav-link:hover {
    @apply text-blue-600 dark:text-blue-400;
  }

  .header-at-top .logo-text {
    @apply text-gray-800 dark:text-white;
  }

  .header-at-top .theme-icon {
    @apply text-gray-700 dark:text-white/90;
  }

  .header-at-top .theme-icon:hover {
    @apply text-gray-900 dark:text-white;
  }

  .header-at-top button {
    @apply text-gray-700 dark:text-white/90 bg-white/50 dark:bg-white/10 hover:bg-white/80 dark:hover:bg-white/20;
  }

  .header-at-top .mobile-menu-bg {
    @apply bg-transparent;
  }

  .header-at-top .mobile-link {
    @apply text-gray-700 dark:text-white/80;
  }

  .header-at-top .mobile-link:hover {
    @apply text-blue-600 dark:text-blue-400;
  }

  /* Scrolled state - white background with blur */
  .header-scrolled {
    @apply bg-white/90 dark:bg-dark-bg/90 backdrop-blur-md border-b border-gray-200 dark:border-dark-border;
  }

  .header-scrolled .nav-link {
    @apply text-gray-600 dark:text-dark-text-secondary;
  }

  .header-scrolled .nav-link:hover {
    @apply text-primary dark:text-accent;
  }

  .header-scrolled .logo-text {
    @apply text-gray-900 dark:text-dark-text;
  }

  .header-scrolled .theme-icon {
    @apply text-gray-500 dark:text-dark-text-secondary;
  }

  .header-scrolled .theme-icon:hover {
    @apply text-gray-700 dark:text-white;
  }

  .header-scrolled button {
    @apply text-gray-600 dark:text-dark-text-secondary bg-gray-100 dark:bg-dark-bg-secondary hover:bg-gray-200 dark:hover:bg-slate-700;
  }

  .header-scrolled .mobile-menu-bg {
    @apply bg-white/95 dark:bg-dark-bg/95 backdrop-blur-md border-b border-gray-200 dark:border-dark-border;
  }

  .header-scrolled .mobile-link {
    @apply text-gray-500 dark:text-dark-text-secondary;
  }

  .header-scrolled .mobile-link:hover {
    @apply text-primary dark:text-accent;
  }
</style>