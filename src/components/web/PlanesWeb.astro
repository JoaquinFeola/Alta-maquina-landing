---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import * as Icons from '@tabler/icons-react';
import { planesWeb, planesMantenimiento, extras } from '../../data/planes';

const iconMap: Record<string, any> = {
  'IconPackage': Icons.IconPackage,
  'IconWorld': Icons.IconWorld,
  'IconCalendar': Icons.IconCalendar,
  'IconShoppingCart': Icons.IconShoppingCart,
  'IconBolt': Icons.IconBolt,
};

const { IconStar, IconCheck, IconX, IconArrowRight } = Icons;
---

<section id="planes" class="relative py-20 lg:py-32 bg-white dark:bg-slate-950 overflow-hidden">
  <!-- Glowing Background Orbs -->
  <div class="absolute top-[20%] right-[-10%] w-[30vw] h-[30vw] rounded-full bg-indigo-500/5 dark:bg-indigo-500/5 blur-3xl animate-float-slow"></div>
  <div class="absolute bottom-[20%] left-[-10%] w-[35vw] h-[35vw] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-3xl animate-float-slower"></div>

  <Container class="relative z-10">
    <SectionTitle
      title="Nuestros planes"
      highlight="planes"
      subtitle="Elegí el plan ideal para tu negocio. Todos los desarrollos incluyen diseño responsive, optimización SEO y botón de WhatsApp."
    />

    <!-- Premium glass tabs navigation -->
    <div class="flex justify-center mb-16">
      <div class="inline-flex p-1.5 rounded-2xl bg-gray-100/80 dark:bg-slate-900/60 border border-gray-200/50 dark:border-white/5 backdrop-blur-md">
        <button class="tab-btn active px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-300 cursor-pointer" data-tab="desarrollo">
          Desarrollo Web
        </button>
        <button class="tab-btn px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-300 cursor-pointer" data-tab="mantenimiento">
          Mantenimiento
        </button>
        <button class="tab-btn px-6 py-3 rounded-xl text-sm font-semibold transition-all duration-300 cursor-pointer" data-tab="extras">
          Extras
        </button>
      </div>
    </div>

    <!-- Tab: Desarrollo Web -->
    <div class="tab-content active" id="tab-desarrollo">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
        {planesWeb.map((plan) => {
          const PlanIcon = iconMap[plan.icono];
          return (
            <div class:list={[
              'group relative flex flex-col justify-between bg-white dark:bg-slate-900/40 border rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1.5 overflow-hidden',
              plan.popular
                ? 'border-blue-600 dark:border-blue-500 shadow-xl shadow-blue-500/5 dark:shadow-blue-500/10 scale-102 z-10 ring-1 ring-blue-600/30'
                : 'border-gray-200 dark:border-slate-800 hover:border-blue-500/40 dark:hover:border-blue-400/40 hover:shadow-lg'
            ]}>
              {/* Popular badge */}
              {plan.popular && (
                <div class="absolute -top-1 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1 px-4 py-1 rounded-b-xl text-[10px] font-bold uppercase tracking-wider bg-blue-600 dark:bg-blue-500 text-white shadow-md">
                    <IconStar className="w-3.5 h-3.5 fill-current text-white animate-pulse" />
                    Más Popular
                  </span>
                </div>
              )}

              <div>
                <!-- Icon + Title -->
                <div class="flex items-center gap-4 mb-6">
                  <div class:list={[
                    'p-3 rounded-2xl shadow-inner',
                    plan.popular
                      ? 'bg-blue-600 text-white shadow-blue-500/35'
                      : 'bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 group-hover:bg-blue-50 dark:group-hover:bg-blue-900/30 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors'
                  ]}>
                    {PlanIcon && <PlanIcon className="w-6 h-6" />}
                  </div>
                  <div>
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white">{plan.nombre}</h3>
                    {plan.popular && <span class="text-[10px] font-medium text-blue-600 dark:text-blue-400">Recomendado</span>}
                  </div>
                </div>

                <!-- Price and details -->
                <div class="mb-6">
                  <span class="text-3xl sm:text-4xl font-extrabold text-blue-600 dark:text-blue-400 tracking-tight">{plan.precio}</span>
                  {plan.nota && <p class="text-[11px] text-gray-400 dark:text-slate-500 mt-1 italic">* {plan.nota}</p>}
                </div>

                <!-- Description -->
                <p class="text-sm text-gray-600 dark:text-slate-300 mb-6 leading-relaxed">{plan.descripcion}</p>

                <!-- Divider -->
                <div class="h-px bg-gray-100 dark:bg-slate-800/80 mb-6"></div>

                <!-- Incluye list -->
                <div class="space-y-4 mb-8">
                  <h4 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-widest">¿Qué incluye?</h4>
                  <ul class="space-y-3">
                    {plan.incluye.map((item) => (
                      <li class="text-sm text-gray-600 dark:text-slate-300 flex items-start gap-2.5">
                        <IconCheck className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                <!-- No incluye list -->
                {plan.noIncluye && plan.noIncluye.length > 0 && (
                  <div class="space-y-4 pt-6 border-t border-gray-100 dark:border-slate-800/80 mb-8">
                    <h4 class="text-xs font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">No incluye</h4>
                    <ul class="space-y-2">
                      {plan.noIncluye.map((item) => (
                        <li class="text-xs text-gray-400 dark:text-slate-500 flex items-start gap-2.5">
                          <IconX className="w-4 h-4 text-gray-300 dark:text-slate-700 mt-0.5 flex-shrink-0" />
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <!-- Button CTA -->
              <div class="mt-auto pt-4">
                <a
                  href="#contacto"
                  data-select-plan={plan.nombre}
                  class:list={[
                    'select-plan-trigger w-full py-3.5 px-6 font-semibold text-sm rounded-2xl flex items-center justify-center gap-2 transition-all duration-300 hover:scale-[1.02]',
                    plan.popular
                      ? 'bg-blue-600 hover:bg-blue-700 text-white shadow-lg shadow-blue-500/20'
                      : 'bg-slate-100 dark:bg-slate-800 text-gray-800 dark:text-slate-200 hover:bg-blue-600 hover:text-white dark:hover:bg-blue-600 dark:hover:text-white'
                  ]}
                >
                  Elegir plan
                  <IconArrowRight className="w-4 h-4" />
                </a>

                {/* Examples */}
                {plan.ejemplos && (
                  <div class="mt-6 pt-4 border-t border-gray-100 dark:border-slate-800/80">
                    <p class="text-[11px] text-gray-400 dark:text-slate-500 mb-2">Páginas incluidas:</p>
                    <div class="flex flex-wrap gap-1.5">
                      {plan.ejemplos.map((ej) => (
                        <span class="px-2 py-0.5 text-[10px] font-medium rounded-md bg-gray-50 dark:bg-slate-900 text-gray-500 dark:text-slate-400 border border-gray-200/50 dark:border-white/5">
                          {ej}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Tab: Mantenimiento -->
    <div class="tab-content hidden" id="tab-mantenimiento">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
          {planesMantenimiento.map((plan) => (
            <div class="group relative flex flex-col justify-between bg-white dark:bg-slate-900/40 border border-gray-200 dark:border-slate-800 rounded-3xl p-8 transition-all duration-300 hover:-translate-y-1.5 hover:border-blue-500/40 dark:hover:border-blue-400/40 hover:shadow-lg">
              <div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{plan.nombre}</h3>
                <div class="mb-4">
                  <span class="text-3xl font-extrabold text-blue-600 dark:text-blue-400 tracking-tight">{plan.precio}</span>
                </div>
                <p class="text-sm text-gray-600 dark:text-slate-300 mb-6 leading-relaxed">{plan.descripcion}</p>

                <!-- Divider -->
                <div class="h-px bg-gray-100 dark:bg-slate-800/80 mb-6"></div>

                <div class="space-y-4 mb-8">
                  <h4 class="text-xs font-bold text-gray-900 dark:text-white uppercase tracking-widest">Incluye</h4>
                  <ul class="space-y-3">
                    {plan.incluye.map((item) => (
                      <li class="text-sm text-gray-600 dark:text-slate-300 flex items-start gap-2.5">
                        <IconCheck className="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {plan.noIncluye && plan.noIncluye.length > 0 && (
                  <div class="space-y-4 pt-6 border-t border-gray-100 dark:border-slate-800/80 mb-8">
                    <h4 class="text-xs font-bold text-gray-400 dark:text-slate-500 uppercase tracking-widest">No incluye</h4>
                    <ul class="space-y-2">
                      {plan.noIncluye.map((item) => (
                        <li class="text-xs text-gray-400 dark:text-slate-500 flex items-start gap-2.5">
                          <IconX className="w-4 h-4 text-gray-300 dark:text-slate-700 mt-0.5 flex-shrink-0" />
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <a
                href="#contacto"
                data-select-plan={plan.nombre}
                class="select-plan-trigger mt-auto w-full py-3.5 px-6 font-semibold text-sm rounded-2xl flex items-center justify-center gap-2 bg-slate-100 dark:bg-slate-800 text-gray-800 dark:text-slate-200 hover:bg-blue-600 hover:text-white dark:hover:bg-blue-600 dark:hover:text-white transition-all duration-300 hover:scale-[1.02]"
              >
                Contratar mantenimiento
                <IconArrowRight className="w-4 h-4" />
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Tab: Extras -->
    <div class="tab-content hidden" id="tab-extras">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-slate-900/40 border border-gray-200 dark:border-slate-800 rounded-3xl p-6 sm:p-10 shadow-lg backdrop-blur-md">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">Servicios Adicionales</h3>
          
          <div class="space-y-3">
            {extras.map((extra) => (
              <div class="flex items-center justify-between p-4 bg-slate-50/50 dark:bg-slate-950/40 border border-gray-100 dark:border-slate-800/50 rounded-2xl transition-all duration-300 hover:bg-blue-50/40 dark:hover:bg-blue-950/20">
                <span class="text-gray-800 dark:text-slate-200 font-semibold text-sm">{extra.servicio}</span>
                <span class="text-blue-600 dark:text-blue-400 font-extrabold text-sm">{extra.precio}</span>
              </div>
            ))}
          </div>
          
          <p class="text-sm text-gray-500 dark:text-slate-400 text-center mt-8">
            ¿Necesitás un desarrollo a medida o un servicio que no está en la lista?
          </p>
          
          <div class="mt-6 flex justify-center">
            <a
              href="#contacto"
              data-select-plan="Web Personalizada - Cotización"
              class="select-plan-trigger py-3 px-6 bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm rounded-2xl hover:shadow-lg hover:shadow-blue-600/20 hover:scale-105 transition-all duration-300 inline-flex items-center gap-2"
            >
              Pedir presupuesto personalizado
              <IconArrowRight className="w-4.5 h-4.5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  // Tab System
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  function setActiveTab(tabId: string) {
    tabBtns.forEach((btn) => {
      const isActive = btn.getAttribute('data-tab') === tabId;
      btn.classList.toggle('bg-blue-600', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('shadow-md', isActive);
      btn.classList.toggle('bg-transparent', !isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('dark:text-slate-400', !isActive);
    });

    tabContents.forEach((content) => {
      const el = content as HTMLElement;
      el.classList.toggle('hidden', el.id !== `tab-${tabId}`);
      el.classList.toggle('active', el.id === `tab-${tabId}`);
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');
      if (tabId) setActiveTab(tabId);
    });
  });

  // Initialize
  setActiveTab('desarrollo');

  // Plan Selection Hook (UX detailing)
  // When user clicks "Elegir plan", automatically set the dropdown value in ContactForm
  const selectPlanTriggers = document.querySelectorAll('.select-plan-trigger');
  
  selectPlanTriggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const planName = trigger.getAttribute('data-select-plan');
      if (!planName) return;

      // Find the select wrapper
      const wrapper = document.querySelector('.custom-select-wrapper');
      if (!wrapper) return;

      const triggerBtn = wrapper.querySelector('.custom-select-trigger');
      const selectedText = wrapper.querySelector('.selected-text');
      const nativeSelect = wrapper.querySelector('.native-select') as HTMLSelectElement;
      const dropdown = wrapper.querySelector('.custom-select-dropdown');

      if (!nativeSelect || !selectedText) return;

      // Find matching option (fuzzy match or exact)
      let foundValue = "";
      let foundLabel = "";

      for (let i = 0; i < nativeSelect.options.length; i++) {
        const option = nativeSelect.options[i];
        if (option.value.toLowerCase().includes(planName.toLowerCase()) || planName.toLowerCase().includes(option.value.toLowerCase())) {
          foundValue = option.value;
          foundLabel = option.text;
          break;
        }
      }

      if (foundValue) {
        nativeSelect.value = foundValue;
        selectedText.textContent = foundLabel;
        selectedText.classList.remove('text-gray-400', 'dark:text-gray-500');
        selectedText.classList.add('text-gray-900', 'dark:text-dark-text');

        // Update active checkmarks inside the custom select dropdown if open
        if (dropdown) {
          dropdown.querySelectorAll('.custom-select-option').forEach(opt => {
            const check = opt.querySelector('.check-icon') || opt.querySelector('svg');
            const optVal = opt.getAttribute('data-value');
            if (optVal === foundValue) {
              opt.classList.add('bg-gray-50', 'dark:bg-white/5');
              check?.classList.remove('opacity-0');
              check?.classList.add('opacity-100');
            } else {
              opt.classList.remove('bg-gray-50', 'dark:bg-white/5');
              check?.classList.remove('opacity-100');
              check?.classList.add('opacity-0');
            }
          });
        }
      }
    });
  });
</script>

<style>
  .tab-content.active {
    display: block;
    animation: fadeIn 300ms ease-out;
  }
  .tab-content.hidden {
    display: none;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
