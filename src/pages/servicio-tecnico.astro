---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroPC from '../components/pc/HeroPC.astro';
import ServiciosPC from '../components/pc/ServiciosPC.astro';
import PreciosPC from '../components/pc/PreciosPC.astro';
import CTAPC from '../components/pc/CTAPC.astro';
import FAQAccordion from '../components/ui/FAQAccordion.astro';
import { faqPC } from '../data/faq-pc';
---

<Layout
  title="Alta Maquina | Servicio Técnico PC en Partido de la Costa"
  pageType="pc"
  faqs={faqPC}
>
  <Header page="pc" />
  
  <main class="flex-1 pt-16">
    <HeroPC />
    <ServiciosPC />
    <PreciosPC />
    <FAQAccordion
      title="Preguntas frecuentes"
      highlight="frecuentes"
      subtitle="Todo lo que necesitás saber sobre nuestro servicio técnico de PC"
      faqs={faqPC}
    />
    <CTAPC />
  </main>
  
  <Footer />
</Layout>
