---
export const prerender = false;
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import SocialLinks from '../ui/SocialLinks.astro';
import ContactForm from './ContactForm.astro';
import * as Icons from '@tabler/icons-react';
import { nombreContacto } from '../../data/social';
---

<section id="contacto" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg">
  <Container>
    <SectionTitle
      title="¿Listo para potenciar tu negocio?"
      highlight="potenciar"
      subtitle="Elegí cómo contactarnos o completá el formulario"
    />

    <div class="max-w-2xl mx-auto">
      {/* Social links - smaller */}
      <div class="mb-8">
        <SocialLinks showName={true} size="md" layout="row" />
      </div>

      {/* Or separator */}
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px bg-gray-200 dark:bg-dark-border"></div>
        <span class="text-sm text-gray-400 dark:text-gray-500">o</span>
        <div class="flex-1 h-px bg-gray-200 dark:bg-dark-border"></div>
      </div>

      {/* Contact Form */}
      <ContactForm />
    </div>
  </Container>
</section>
