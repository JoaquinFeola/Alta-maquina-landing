---
import * as Icons from '@tabler/icons-react';
import { nombreContacto } from '../../data/social';
import AltaMaquinaImagotipo from "../../assets/images/Logo-alta-maquina-sin-fondo.webp";
import { Image } from "astro:assets";

const { IconBrandWhatsapp, IconX, IconSend } = Icons;

interface Props {
  phone?: string;
  defaultMessage?: string;
}

const {
  phone = "5492246505707", // Default phone based on area Partido de la Costa
  defaultMessage = "¡Hola Joaquín! Vi la web de Alta Máquina y me gustaría consultar sobre..."
} = Astro.props;

const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(defaultMessage)}`;
---

<div class="fixed bottom-6 right-6 z-50 flex flex-col items-end font-sans">
  <!-- Chat Window -->
  <div
    id="whatsapp-chat-window"
    class="mb-4 w-[330px] rounded-2xl overflow-hidden shadow-2xl border border-gray-100 dark:border-white/10 bg-white dark:bg-slate-900 transition-all duration-300 translate-y-4 opacity-0 pointer-events-none scale-95 origin-bottom-right"
  >
    <!-- Header -->
    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white p-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="relative">
          <Image
            src={AltaMaquinaImagotipo}
            alt={nombreContacto}
            class="w-10 h-10 rounded-full bg-white p-0.5 border border-white/20"
          />
          <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 rounded-full border-2 border-white dark:border-slate-900"></span>
        </div>
        <div>
          <h4 class="font-semibold text-sm leading-tight">{nombreContacto}</h4>
          <span class="text-xs text-white/80">Soporte Alta Máquina</span>
        </div>
      </div>
      <button
        type="button"
        id="close-whatsapp-chat"
        class="text-white/80 hover:text-white p-1 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Cerrar chat"
      >
        <IconX className="w-5 h-5" />
      </button>
    </div>

    <!-- Message Body -->
    <div class="p-4 bg-gray-50 dark:bg-slate-950/40 min-h-[140px] flex flex-col justify-end space-y-3">
      <div class="bg-white dark:bg-slate-800 p-3 rounded-2xl rounded-tl-none shadow-sm max-w-[85%] border border-gray-100 dark:border-white/5">
        <p class="text-xs text-gray-400 dark:text-slate-400 mb-1 font-medium">{nombreContacto}</p>
        <p class="text-sm text-gray-800 dark:text-slate-100">
          ¡Hola! 👋 ¿Cómo estás? ¿En qué puedo ayudarte hoy?
        </p>
        <span class="block text-[10px] text-right text-gray-400 dark:text-slate-500 mt-1">Justo ahora</span>
      </div>
      <div class="bg-white dark:bg-slate-800 p-3 rounded-2xl rounded-tl-none shadow-sm max-w-[85%] border border-gray-100 dark:border-white/5">
        <p class="text-sm text-gray-800 dark:text-slate-100">
          ¿Buscás una página web para tu negocio o necesitás reparar tu computadora?
        </p>
        <span class="block text-[10px] text-right text-gray-400 dark:text-slate-500 mt-1">Justo ahora</span>
      </div>
    </div>

    <!-- Footer Action -->
    <div class="p-3 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-white/5 flex gap-2">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full py-2.5 px-4 bg-green-500 hover:bg-green-600 text-white font-medium text-sm rounded-xl transition-all duration-200 flex items-center justify-center gap-2 shadow-lg shadow-green-500/10 hover:shadow-green-500/20"
      >
        <IconBrandWhatsapp className="w-5 h-5" />
        Preguntar por WhatsApp
      </a>
    </div>
  </div>

  <!-- Trigger Button -->
  <button
    type="button"
    id="whatsapp-trigger"
    class="flex items-center justify-center p-3 sm:p-4 bg-green-500 hover:bg-green-600 text-white rounded-full shadow-2xl transition-all duration-300 hover:scale-105 group relative overflow-hidden"
    aria-label="Abrir chat de WhatsApp"
  >
    <!-- Ripple/Pulse effect -->
    <span class="absolute inset-0 bg-white/20 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 origin-center"></span>
    
    <span class="relative flex h-6 w-6 flex-shrink-0">
      <!-- Glow ping -->
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-40"></span>
      <IconBrandWhatsapp className="w-6 h-6 relative" />
    </span>
    
    <span class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-500 ease-in-out font-medium text-sm whitespace-nowrap hidden sm:inline-block group-hover:ml-2">
      Escribinos
    </span>
  </button>
</div>

<script>
  const trigger = document.getElementById('whatsapp-trigger');
  const chatWindow = document.getElementById('whatsapp-chat-window');
  const closeBtn = document.getElementById('close-whatsapp-chat');

  function toggleChat() {
    if (chatWindow) {
      const isOpen = !chatWindow.classList.contains('opacity-0');
      if (isOpen) {
        // Close
        chatWindow.classList.add('opacity-0', 'pointer-events-none', 'scale-95', 'translate-y-4');
        chatWindow.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100', 'translate-y-0');
      } else {
        // Open
        chatWindow.classList.remove('opacity-0', 'pointer-events-none', 'scale-95', 'translate-y-4');
        chatWindow.classList.add('opacity-100', 'pointer-events-auto', 'scale-100', 'translate-y-0');
      }
    }
  }

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleChat();
  });

  closeBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleChat();
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (chatWindow && !chatWindow.contains(e.target as Node) && !trigger?.contains(e.target as Node)) {
      chatWindow.classList.add('opacity-0', 'pointer-events-none', 'scale-95', 'translate-y-4');
      chatWindow.classList.remove('opacity-100', 'pointer-events-auto', 'scale-100', 'translate-y-0');
    }
  });
</script>
