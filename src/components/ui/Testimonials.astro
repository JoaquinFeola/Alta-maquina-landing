---
import Container from '../Container.astro';
import SectionTitle from './SectionTitle.astro';
import * as Icons from '@tabler/icons-react';

const { IconQuote, IconExternalLink, IconStar } = Icons;

interface Testimonial {
  nombre: string;
  rol: string;
  empresa: string;
  contenido: string;
  estrellas: number;
  tipo: 'web' | 'pc';
}

const testimonios: Testimonial[] = [
  {
    nombre: "Carolina Rossi",
    rol: "Fundadora",
    empresa: "Wanderlust Indumentaria",
    contenido: "Excelente servicio. La tienda online quedó increíble, es súper rápida y fácil de comprar para nuestros clientes. Joaquín captó al instante el diseño moderno que buscábamos y siempre nos dio el mejor soporte técnico. El ecommerce cambió por completo nuestras ventas.",
    estrellas: 5,
    tipo: 'web'
  },
  {
    nombre: "Mariano Gómez",
    rol: "Propietario",
    empresa: "Gómez Automotores",
    contenido: "Excelente atención y rapidez. Llevé mi computadora de la oficina que no encendía para diagnóstico y limpieza. En menos de dos horas ya la tenía funcionando de nuevo como si fuera nueva. Totalmente transparente con el presupuesto.",
    estrellas: 5,
    tipo: 'pc'
  },
  {
    nombre: "Clara Fernández",
    rol: "Odontóloga",
    empresa: "Consultorio Integral",
    contenido: "Contratamos el Plan Turnos Online para el consultorio y fue la mejor decisión. Los pacientes ahora reservan directamente desde su celular y nosotros administramos todo de manera súper sencilla. Súper profesional y recomendable.",
    estrellas: 5,
    tipo: 'web'
  }
];
---

<section id="testimonios" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg/60 overflow-hidden">
  <!-- Glowing Background Orbs -->
  <div class="absolute top-1/4 left-1/3 w-96 h-96 bg-blue-500/5 dark:bg-blue-500/10 rounded-full blur-3xl animate-float-slow"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-purple-500/5 dark:bg-purple-500/10 rounded-full blur-3xl animate-float-slower"></div>

  <Container class="relative z-10">
    <SectionTitle
      title="Casos de éxito y opiniones"
      highlight="opiniones"
      subtitle="Descubrí la experiencia de los clientes que ya confían en Alta Máquina"
    />

    <!-- Case Study Showcase: Wanderlust -->
    <div class="max-w-5xl mx-auto mb-16">
      <div class="relative group bg-white dark:bg-dark-bg-secondary border border-gray-200/60 dark:border-white/10 rounded-3xl p-6 sm:p-10 shadow-xl overflow-hidden glow-card">
        <!-- Floating badge -->
        <div class="absolute top-6 right-6">
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 border border-blue-200/50 dark:border-blue-800/50">
            Proyecto Destacado
          </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
          <!-- Text content -->
          <div class="lg:col-span-7 space-y-6">
            <div class="flex items-center gap-1 text-yellow-400">
              {[...Array(5)].map(() => (
                <IconStar className="w-5 h-5 fill-current" />
              ))}
            </div>
            
            <IconQuote className="w-12 h-12 text-blue-600/20 dark:text-blue-400/20 -mb-4" />
            
            <p class="text-base sm:text-lg text-gray-700 dark:text-dark-text-secondary italic leading-relaxed">
              "{testimonios[0].contenido}"
            </p>

            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-blue-600 to-indigo-600 flex items-center justify-center text-white font-bold text-lg shadow-lg">
                CR
              </div>
              <div>
                <h4 class="font-bold text-gray-900 dark:text-dark-text">{testimonios[0].nombre}</h4>
                <p class="text-xs text-gray-500 dark:text-dark-text-secondary">{testimonios[0].rol} de <span class="font-semibold text-blue-600 dark:text-blue-400">{testimonios[0].empresa}</span></p>
              </div>
            </div>
          </div>

          <!-- Interactive Mockup representation -->
          <div class="lg:col-span-5 flex flex-col justify-center items-center lg:items-end">
            <div class="relative w-full max-w-[280px] sm:max-w-[320px] aspect-video sm:aspect-square bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-slate-800 dark:to-indigo-950/40 rounded-2xl border border-gray-200 dark:border-white/10 p-4 shadow-inner flex flex-col justify-between group-hover:scale-[1.02] transition-transform duration-300">
              <!-- Visual representation of shop -->
              <div class="flex justify-between items-center border-b border-gray-200/50 dark:border-white/5 pb-2">
                <span class="text-xs font-bold tracking-widest uppercase text-gray-400">Wanderlust</span>
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
              </div>
              
              <div class="my-auto space-y-2 py-4">
                <div class="h-2 bg-blue-600/20 dark:bg-blue-400/20 rounded w-1/2"></div>
                <div class="h-4 bg-gray-300 dark:bg-white/10 rounded w-3/4"></div>
                <div class="h-4 bg-gray-300 dark:bg-white/10 rounded w-full"></div>
                <div class="flex gap-2 pt-2">
                  <div class="h-8 w-1/2 bg-blue-600 dark:bg-blue-500 rounded-lg flex items-center justify-center text-[10px] text-white font-semibold">Comprar</div>
                  <div class="h-8 w-1/2 border border-gray-300 dark:border-white/10 rounded-lg flex items-center justify-center text-[10px] text-gray-600 dark:text-gray-400">Detalles</div>
                </div>
              </div>

              <div class="text-[10px] text-center text-gray-400 dark:text-slate-500 pt-2 border-t border-gray-200/50 dark:border-white/5">
                Tienda Online Completa
              </div>
            </div>

            <!-- Live Site Link -->
            <a
              href="https://wanderlust.altamaquina.com"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/20 hover:scale-105"
            >
              Ver sitio en vivo
              <IconExternalLink className="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Secondary Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {testimonios.slice(1).map((item) => (
        <div class="bg-white dark:bg-dark-bg-secondary border border-gray-200/60 dark:border-white/10 rounded-2xl p-6 sm:p-8 shadow-md flex flex-col justify-between hover:shadow-lg transition-shadow duration-300">
          <div>
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1 text-yellow-400">
                {[...Array(item.estrellas)].map(() => (
                  <IconStar className="w-4 h-4 fill-current" />
                ))}
              </div>
              <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${item.tipo === 'web' ? 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400' : 'bg-cyan-50 dark:bg-cyan-900/20 text-cyan-600 dark:text-cyan-400'}`}>
                {item.tipo === 'web' ? 'Desarrollo Web' : 'Servicio Técnico'}
              </span>
            </div>
            
            <p class="text-sm sm:text-base text-gray-600 dark:text-dark-text-secondary italic mb-6 leading-relaxed">
              "{item.contenido}"
            </p>
          </div>

          <div class="flex items-center gap-3 border-t border-gray-100 dark:border-dark-border pt-4">
            <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center font-bold text-sm text-gray-700 dark:text-white">
              {item.nombre.split(' ').map(n => n[0]).join('')}
            </div>
            <div>
              <h4 class="font-semibold text-sm text-gray-900 dark:text-dark-text">{item.nombre}</h4>
              <p class="text-[11px] text-gray-500 dark:text-dark-text-secondary">{item.rol} — {item.empresa}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
