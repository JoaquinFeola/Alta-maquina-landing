---
import Container from './Container.astro';

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-100 dark:bg-dark-bg border-t border-gray-200 dark:border-dark-border py-12">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
          <img src="/favicon.svg" alt="Alta Maquina" class="w-8 h-8 rounded-full object-cover mb-4" />
        </a>
        <p class="text-sm text-gray-600 dark:text-dark-text-secondary">
          Limpieza, armado y mantenimiento de computadoras.
        </p>
        <p class="text-xs text-gray-500 dark:text-dark-text-secondary mt-4">
          Joaquín Feola
        </p>
      </div>
      
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-4">Contacto</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-dark-text-secondary">
          <li>
            <a href="tel:+5491134477270" class="hover:text-primary dark:hover:text-accent transition-colors">
              +54 9 11 3447-7270
            </a>
          </li>
          <li>
            <span>San Bernardo del Tuyú, La Costa</span>
          </li>
          <li>
            <span>Buenos Aires, Argentina</span>
          </li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-4">Servicios</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-dark-text-secondary">
          <li>
            <span>Limpieza de equipos</span>
          </li>
          <li>
            <span>Armado de PC a medida</span>
          </li>
          <li>
            <span>Mantenimiento</span>
          </li>
          <li>
            <span>Desarrollo web</span>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-dark-border text-center">
      <p class="text-xs text-gray-500 dark:text-dark-text-secondary">
        © {currentYear} Alta Maquina. Todos los derechos reservados.
      </p>
    </div>
  </Container>
</footer>