---
import Container from './Container.astro';
import * as Icons from '@tabler/icons-react';

const { IconSparkles, IconDeviceDesktop, IconTool, IconWorld } = Icons;

interface Servicio {
  id: number;
  titulo: string;
  descripcion: string;
  icono: any;
}

const servicios: Servicio[] = [
  {
    id: 1,
    titulo: 'Limpieza física de equipos',
    descripcion: 'Limpieza física completa de tu equipo',
    icono: IconSparkles,
  },
  {
    id: 2,
    titulo: 'Armado de PC a medida',
    descripcion: 'Computadoras a medida para lo que necesites',
    icono: IconDeviceDesktop,
  },
  {
    id: 3,
    titulo: 'Mantenimiento',
    descripcion: 'Preventivo y correctivo para que rinda',
    icono: IconTool,
  },
  {
    id: 4,
    titulo: 'Páginas Web',
    descripcion: 'Desarrollo web de todo tipo',
    icono: IconWorld,
  },
];
---

<section id="servicios" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg">
  <Container>
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-dark-text mb-4">
        Nuestros <span class="text-primary dark:text-accent">servicios</span>
      </h2>
      <p class="text-lg text-gray-500 dark:text-dark-text-secondary max-w-2xl mx-auto">
        Soluciones integrales para mantener tus equipos en óptimas condiciones
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {servicios.map((servicio) => (
        <div class="group relative bg-white dark:bg-dark-bg-secondary border border-gray-200 dark:border-dark-border rounded-2xl p-6 transition-all duration-300 hover:border-primary/50 dark:hover:border-accent/50 hover:bg-white dark:hover:bg-dark-bg-secondary hover:-translate-y-1">
          <!-- Icono -->
          <div class="text-primary dark:text-accent mb-4 transition-transform duration-300 group-hover:scale-110">
            <servicio.icono class="w-8 h-8" />
          </div>

          <!-- Titulo -->
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-dark-text mb-3">
            {servicio.titulo}
          </h3>

          <!-- Descripcion -->
          <p class="text-sm text-gray-500 dark:text-dark-text-secondary leading-relaxed">
            {servicio.descripcion}
          </p>

          <!-- Hover effect line -->
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-primary dark:bg-accent transition-all duration-300 group-hover:w-3/4"></div>
        </div>
      ))}
    </div>
  </Container>
</section>