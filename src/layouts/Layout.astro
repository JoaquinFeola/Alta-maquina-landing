---
import "../styles/global.css";
import { getAllSchemas } from "../utils/schema";

// Preload critical font — get the hashed URL from Vite
import interLatinFontUrl from "../fonts/Inter-Latin.woff2?url";
import interLatinExtFontUrl from "../fonts/Inter-LatinExt.woff2?url";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonicalURL?: string;
  pageType?: "web" | "pc" | "legal" | "faq";
  faqs?: Array<{ pregunta: string; respuesta: string }>;
  pageTitle?: string; // used for legal breadcrumbs
  pagePath?: string;  // used for legal breadcrumbs
}

const siteURL = "https://altamaquina.com";

// Default SEO content by page type
const defaultsByType = {
  web: {
    description:
      "Alta Maquina — Desarrollo web profesional en Argentina. Landing pages, tiendas online, sistemas de turnos y páginas a medida. Presupuestos desde $80.000.",
    keywords:
      "desarrollo web Argentina, creación de páginas web, landing page profesional, tienda online Argentina, e-commerce, sistema de turnos online, web a medida, diseño web profesional, alta maquina, desarrollo web para negocios, páginas web responsive, posicionamiento web",
  },
  pc: {
    description:
      "Alta Maquina — Servicio técnico de PC en Partido de la Costa. Limpieza física desde $14.000, diagnóstico $5.000 y armado de computadoras. Atención en San Bernardo, Santa Teresita y zona.",
    keywords:
      "servicio técnico PC Partido de la Costa, limpieza de PC San Bernardo, diagnóstico computadora, armado de PC, mantenimiento computadoras, limpieza gabinete, cambio pasta térmica, servicio técnico Santa Teresita, Mar del Tuyú, alta maquina",
  },
  legal: {
    description:
      "Políticas de privacidad y términos y condiciones del servicio de Alta Máquina.",
    keywords: "política de privacidad, términos de uso, condiciones, alta maquina",
  },
  faq: {
    description:
      "Preguntas frecuentes sobre nuestros servicios de desarrollo web y servicio técnico de computadoras en Partido de la Costa.",
    keywords: "faq, preguntas frecuentes, desarrollo web faq, servicio tecnico pc faq, alta maquina",
  }
};

const {
  title,
  pageType = "web",
  description = defaultsByType[pageType].description,
  keywords = defaultsByType[pageType].keywords,
  ogImage = `${siteURL}/favicon.svg`,
  canonicalURL = new URL(Astro.url.pathname, siteURL).toString(),
  faqs,
  pageTitle,
  pagePath,
} = Astro.props;

const allSchemas = getAllSchemas(siteURL, ogImage, pageType, description, faqs, pageTitle, pagePath);
---

<!doctype html>
<html lang="es-AR" class="transition-colors duration-300">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Fonts Preconnect and Outfit font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Preload critical fonts — eliminates font discovery delay -->
    <link rel="preload" href={interLatinFontUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={interLatinExtFontUrl} as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="AltaMaquina" />

    <link rel="canonical" href={canonicalURL} />

    <!-- Meta tags básicos -->
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Alta Maquina" />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Alta Maquina" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- Schema.org structured data: Organization + BreadcrumbList + Page + FAQ -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme");
        // Default to light if no saved preference
        const theme = savedTheme || "light";

        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      html.dark {
        background-color: #0f172a;
        color: #f1f5f9;
      }

      html:not(.dark) {
        background-color: #ffffff;
        color: #111827;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', 'Inter', system-ui, sans-serif;
        letter-spacing: -0.02em;
      }

      .fade-in-section {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s ease-out,
          transform 0.6s ease-out;
      }

      .fade-in-section.is-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body
    class="bg-white dark:bg-dark-bg text-gray-900 dark:text-dark-text antialiased min-h-screen flex flex-col transition-colors duration-300"
  >
    <slot />
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // Defer manifest loading — removes it from the critical rendering path
        const manifest = document.createElement("link");
        manifest.rel = "manifest";
        manifest.href = "/site.webmanifest";
        document.head.appendChild(manifest);

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document.querySelectorAll("section").forEach((section) => {
          section.classList.add("fade-in-section");
          observer.observe(section);
        });
      });
    </script>
  </body>
</html>
