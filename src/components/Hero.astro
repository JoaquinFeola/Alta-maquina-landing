---
import Container from './Container.astro';
import Button from './Button.astro';
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Dramatic background with strong gradient - supports both themes -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-gray-100 dark:bg-gray-900">
    <!-- Intense gradient background: blue -> purple -> pink (dark mode) -->
    <div class="absolute inset-0 hidden dark:block dark:bg-gradient-to-br dark:from-slate-900 dark:via-indigo-950 dark:to-purple-950"></div>

    <!-- More vibrant accent gradients (both modes) -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(59,130,246,0.3)_0%,_transparent_50%)] dark:bg-[radial-gradient(ellipse_at_top_left,_rgba(59,130,246,0.4)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(139,92,246,0.3)_0%,_transparent_50%)] dark:bg-[radial-gradient(ellipse_at_top_right,_rgba(139,92,246,0.35)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(236,72,153,0.25)_0%,_transparent_50%)] dark:bg-[radial-gradient(ellipse_at_bottom_left,_rgba(236,72,153,0.25)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(99,102,241,0.35)_0%,_transparent_60%)] dark:bg-[radial-gradient(ellipse_at_center,_rgba(99,102,241,0.2)_0%,_transparent_60%)]"></div>

    <!-- More pronounced grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.15)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.15)_1px,transparent_1px)] bg-[size:40px_40px] dark:bg-[linear-gradient(rgba(99,102,241,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.08)_1px,transparent_1px)] dark:bg-[size:40px_40px]"></div>

    <!-- Floating decorative elements (both modes) -->
    <div class="absolute top-16 left-8 w-40 h-40 bg-blue-500/20 rounded-2xl rotate-12 blur-xl animate-pulse dark:bg-blue-500/20"></div>
    <div class="absolute top-32 right-16 w-32 h-32 bg-purple-500/20 rounded-2xl -rotate-12 blur-xl animate-pulse dark:bg-purple-500/20" style="animation-delay: 1s;"></div>
    <div class="absolute bottom-32 left-1/4 w-24 h-24 bg-pink-500/20 rounded-2xl rotate-6 blur-xl animate-pulse dark:bg-pink-500/15" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-16 right-1/3 w-36 h-36 bg-indigo-500/20 rounded-2xl -rotate-6 blur-xl animate-pulse dark:bg-indigo-500/15" style="animation-delay: 0.5s;"></div>

    <!-- Geometric shapes (both modes) -->
    <div class="absolute top-20 right-8 w-20 h-20 border border-blue-500/20 rotate-45 dark:border-blue-500/20"></div>
    <div class="absolute bottom-40 left-12 w-16 h-16 border border-purple-500/20 rotate-12 dark:border-purple-500/20"></div>
    <div class="absolute top-1/2 left-8 w-12 h-12 bg-gradient-to-br from-blue-500/20 to-purple-500/20 rounded-lg rotate-12 dark:bg-gradient-to-br dark:from-blue-500/10 dark:to-purple-500/10"></div>

    <!-- Website mockup (large decorative element - both modes) -->
    <div class="absolute right-4 top-1/2 -translate-y-1/2 w-[45%] max-w-xl hidden xl:block">
      <div class="relative">
        <!-- Glow behind mockup -->
        <div class="absolute -inset-4 bg-gradient-to-r from-blue-600/20 via-purple-600/20 to-pink-600/20 dark:from-blue-600/30 dark:via-purple-600/30 dark:to-pink-600/30 rounded-2xl blur-2xl"></div>

        <!-- Browser frame mockup (both modes) -->
        <div class="relative bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-2xl border border-gray-200 dark:border-white/10">
          <!-- Browser header -->
          <div class="bg-gray-100 dark:bg-gray-800/80 px-4 py-2.5 flex items-center gap-2">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="h-6 bg-gray-200 dark:bg-gray-700/50 rounded-md flex items-center px-3">
                <div class="w-2/3 h-2 bg-gray-300 dark:bg-gray-600/50 rounded-full"></div>
              </div>
            </div>
          </div>
          <!-- Browser content -->
          <div class="p-4 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-indigo-900 dark:to-purple-900 min-h-[200px]">
            <!-- Fake website content -->
            <div class="space-y-3">
              <div class="h-4 bg-gray-300 dark:bg-white/10 rounded w-3/4"></div>
              <div class="h-4 bg-gray-300 dark:bg-white/10 rounded w-1/2"></div>
              <div class="flex gap-3 mt-4">
                <div class="h-20 w-1/3 bg-gradient-to-br from-blue-200 to-purple-200 dark:from-blue-500/30 dark:to-purple-500/30 rounded-lg"></div>
                <div class="h-20 w-1/3 bg-gradient-to-br from-pink-200 to-purple-200 dark:from-pink-500/30 dark:to-purple-500/30 rounded-lg"></div>
                <div class="h-20 w-1/3 bg-gradient-to-br from-indigo-200 to-blue-200 dark:from-indigo-500/30 dark:to-blue-500/30 rounded-lg"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Left side decorative cards (both modes) -->
    <div class="absolute left-4 top-1/3 w-48 hidden lg:block">
      <div class="relative">
        <div class="absolute -inset-2 bg-gradient-to-r from-purple-500/10 to-pink-500/10 dark:from-purple-500/20 dark:to-pink-500/20 rounded-xl blur-xl"></div>
        <div class="relative bg-white/80 dark:bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-gray-200 dark:border-white/10 shadow-lg dark:shadow-none">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <div class="h-3 bg-gray-300 dark:bg-white/20 rounded w-20"></div>
          </div>
          <div class="h-2 bg-gray-200 dark:bg-white/10 rounded w-full mb-1"></div>
          <div class="h-2 bg-gray-200 dark:bg-white/10 rounded w-2/3"></div>
        </div>
      </div>
    </div>

    <div class="absolute left-8 bottom-32 w-40 hidden lg:block">
      <div class="relative">
        <div class="absolute -inset-2 bg-gradient-to-r from-blue-500/10 to-indigo-500/10 dark:from-blue-500/20 dark:to-indigo-500/20 rounded-xl blur-xl"></div>
        <div class="relative bg-white/80 dark:bg-white/10 backdrop-blur-sm rounded-xl p-3 border border-gray-200 dark:border-white/10 shadow-lg dark:shadow-none">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-6 h-6 rounded-md bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div class="h-2.5 bg-gray-300 dark:bg-white/20 rounded w-16"></div>
          </div>
          <div class="h-2 bg-gray-200 dark:bg-white/10 rounded w-full"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content with glow effect behind -->
  <Container class="relative z-10 py-20">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Glow behind content -->
      <div class="relative inline-block mb-8">
        <div class="absolute -inset-8 bg-gradient-to-r from-blue-500/10 via-purple-500/10 to-pink-500/10 rounded-3xl blur-2xl dark:from-blue-500/20 dark:via-purple-500/20 dark:to-pink-500/20"></div>

        <!-- Enhanced Badge -->
        <div class="relative inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/80 dark:bg-white/10 backdrop-blur-md border border-gray-200 dark:border-white/20 shadow-lg dark:shadow-xl">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue-400"></span>
          </span>
          <span class="text-sm text-gray-700 dark:text-white/90 font-medium">Servicios profesionales</span>
        </div>
      </div>

      <!-- Main title with enhanced gradient text effect -->
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-r from-blue-500/5 via-purple-500/5 to-pink-500/5 rounded-3xl blur-xl dark:from-blue-500/10 dark:via-purple-500/10 dark:to-pink-500/10"></div>
        <h1 class="relative text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
          Tu PC como nuevo,<br class="hidden sm:block" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 dark:from-blue-400 dark:via-purple-400 dark:to-pink-400">tu web lista</span>
        </h1>
      </div>

      <!-- Enhanced subtitle -->
      <p class="text-lg sm:text-xl text-gray-600 dark:text-white/70 mb-10 max-w-2xl mx-auto leading-relaxed">
        Servicios de limpieza, armado y desarrollo web. <span class="text-gray-900 dark:text-white font-medium">Rápido, limpio y profesional.</span>
      </p>

      <!-- CTA buttons with enhanced styling -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-500 to-purple-500 rounded-xl blur opacity-20 group-hover:opacity-50 transition-opacity dark:opacity-30"></div>
          <Button variant="primary" href="#contacto">
            Contactanos
          </Button>
        </div>
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-purple-500 to-pink-500 rounded-xl blur opacity-15 group-hover:opacity-35 transition-opacity dark:opacity-20"></div>
          <Button variant="secondary" href="#servicios">
            Ver servicios
          </Button>
        </div>
      </div>

      <!-- Enhanced scroll indicator -->
      <div class="mt-16 flex justify-center">
        <div class="flex flex-col items-center gap-2 group cursor-pointer">
          <span class="text-xs uppercase tracking-widest text-gray-400 dark:text-white/40 group-hover:text-gray-600 dark:group-hover:text-white/70 transition-colors">Scroll</span>
          <div class="w-6 h-10 rounded-full border-2 border-gray-300 dark:border-white/20 group-hover:border-gray-400 dark:group-hover:border-white/40 transition-colors flex justify-center pt-2">
            <div class="w-1.5 h-3 rounded-full bg-gray-400 dark:bg-white/30 group-hover:bg-gray-600 dark:group-hover:bg-white/60 transition-colors animate-bounce"></div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>