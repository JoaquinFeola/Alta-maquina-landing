---
import Container from './Container.astro';
import * as Icons from '@tabler/icons-react';

const { IconBrandFacebook, IconMail, IconUser } = Icons;

const linkFacebook = 'https://www.facebook.com/altamaquina.sb/';
const linkGmail = 'mailto:altamaquinassb@gmail.com?subject=Consulta desde la web&body=Hola! Me interesa saber más sobre los servicios de Alta Maquina';
---

<section id="contacto" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg">
  <Container>
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-dark-text mb-4">
        ¿Listo para mejorar tu <span class="text-primary dark:text-accent">PC</span> o tu <span class="text-primary dark:text-accent">web</span>?
      </h2>
      <p class="text-lg text-gray-500 dark:text-dark-text-secondary max-w-2xl mx-auto">
        Elegí la forma de contactarte que más te conviene
      </p>
    </div>

    <!-- Contact card -->
    <div class="max-w-xl mx-auto">
      <div class="relative bg-white dark:bg-dark-bg-secondary border border-gray-200 dark:border-dark-border rounded-2xl p-8 sm:p-12">
        <!-- Decorative gradient -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 dark:from-accent/5 to-transparent rounded-2xl pointer-events-none"></div>

        <!-- Content -->
        <div class="relative flex flex-col items-center text-center">
          <!-- Avatar/Icon -->
          <div class="flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 dark:bg-accent/20 border border-primary/20 dark:border-accent/30 mb-6">
            <IconUser class="w-10 h-10 text-primary dark:text-accent" />
          </div>

          <!-- Nombre -->
          <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-8">
            Joaquín Feola
          </h3>

          <!-- Opciones de contacto -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-md">
            <!-- Facebook -->
            <a
              href={linkFacebook}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center gap-2 p-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-blue-600/20"
            >
              <IconBrandFacebook class="w-7 h-7" />
              <span class="text-sm">Facebook</span>
            </a>

            <!-- Gmail -->
            <a
              href={linkGmail}
              class="flex flex-col items-center gap-2 p-4 bg-red-500 hover:bg-red-600 text-white font-medium rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-red-500/20"
            >
              <IconMail class="w-7 h-7" />
              <span class="text-sm">Gmail</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>