---
import Container from '../Container.astro';
import Button from '../Button.astro';
import { Image } from 'astro:assets';
import HeroImage from "../../assets/images/web_hero.webp";
import * as Icons from '@tabler/icons-react';

const { IconDeviceLaptop, IconArrowRight, IconSparkles } = Icons;
---

<section id="hero" class="relative min-h-[95vh] flex items-center justify-center overflow-hidden pt-20">
  <!-- Glowing Background Orbs & Gradients (Wow Factor) -->
  <div class="absolute inset-0 bg-gradient-to-b from-blue-50/40 via-white to-gray-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">
    <!-- Grid pattern with fade-out mask -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(99,102,241,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.05)_1px,transparent_1px)] bg-[size:32px_32px] dark:bg-[linear-gradient(rgba(99,102,241,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.03)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_at_center,white,transparent_80%)]"></div>

    <!-- Giant Glowing Orbs (Tailwind Animations defined in global.css) -->
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-blue-600/10 dark:bg-blue-600/15 blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[45vw] h-[45vw] rounded-full bg-purple-600/10 dark:bg-purple-600/15 blur-3xl animate-float-slower"></div>
    <div class="absolute top-[30%] right-[20%] w-[30vw] h-[30vw] rounded-full bg-cyan-500/10 dark:bg-cyan-500/10 blur-3xl animate-pulse-slow"></div>

    <!-- Background image (blurred, optimized — overlay) -->
    <div class="absolute inset-0 z-0 opacity-20 dark:opacity-10 pointer-events-none">
      <Image
        class="w-full h-full object-cover"
        src={HeroImage}
        alt="Desarrollo web profesional"
        width={1280}
        height={720}
        quality={40}
        sizes="100vw"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />
      <!-- Blur overlay -->
      <div class="absolute inset-0 backdrop-blur-[6px]"></div>
    </div>
  </div>

  <Container class="relative z-10 py-12 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Text / Content Left -->
      <div class="lg:col-span-7 text-center lg:text-left space-y-8 max-w-3xl mx-auto lg:mx-0">
        <!-- Interactive Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border border-gray-200/80 dark:border-white/10 shadow-lg mb-2 hover:scale-[1.02] transition-transform duration-200 cursor-default">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue-600 dark:bg-blue-400"></span>
          </span>
          <span class="text-xs text-gray-700 dark:text-white/95 font-semibold flex items-center gap-1.5">
            Desarrollo Web Profesional <IconSparkles className="w-3.5 h-3.5 text-blue-500" />
          </span>
        </div>

        <!-- Catchy Main Heading -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl xl:text-7xl font-extrabold tracking-tight text-gray-900 dark:text-white leading-tight">
          Potenciá tu negocio.<br />
          <span class="text-gradient-primary">Conquistá internet.</span>
        </h1>

        <!-- High-Conversion Subtitle -->
        <p class="text-lg sm:text-xl text-gray-600 dark:text-dark-text-secondary leading-relaxed max-w-2xl mx-auto lg:mx-0">
          Diseñamos landing pages, tiendas online y sistemas de turnos a medida. Creamos tu identidad digital con velocidad y optimización para capturar clientes desde el primer día.
        </p>

        <!-- CTA Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start items-center">
          <Button variant="primary" href="#planes" class="w-full sm:w-auto shadow-lg shadow-blue-500/20 hover:shadow-blue-500/35 hover:scale-[1.03] transition-all">
            Ver planes y precios <IconArrowRight class="ml-2 w-4 h-4 inline" />
          </Button>
          <Button variant="secondary" href="#contacto" class="w-full sm:w-auto glass hover:bg-gray-100 dark:hover:bg-white/10 hover:scale-[1.03] transition-all">
            Contactar ahora
          </Button>
        </div>

        <!-- Trust Stats Bar (Conversion Driver) -->
        <div class="pt-8 border-t border-gray-200/50 dark:border-white/5 grid grid-cols-2 sm:grid-cols-3 gap-6 max-w-lg mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <span class="block text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">100%</span>
            <span class="text-xs text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider font-semibold">Adaptado a Móvil</span>
          </div>
          <div class="text-center lg:text-left">
            <span class="block text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">SEO</span>
            <span class="text-xs text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider font-semibold">Optimizado Google</span>
          </div>
          <div class="text-center lg:text-left col-span-2 sm:col-span-1">
            <span class="block text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Rápido</span>
            <span class="text-xs text-gray-500 dark:text-dark-text-secondary uppercase tracking-wider font-semibold">Soporte Local</span>
          </div>
        </div>
      </div>

      <!-- Interactive Mockup Right -->
      <div class="lg:col-span-5 hidden lg:block relative">
        <!-- Decorative Glow behind mockup -->
        <div class="absolute -inset-4 bg-gradient-to-r from-blue-600/15 via-purple-600/10 to-cyan-500/15 rounded-3xl blur-2xl animate-pulse-slow"></div>
        
        <!-- Premium glassbrowser mockup -->
        <div class="relative bg-white/70 dark:bg-slate-900/80 backdrop-blur-md rounded-2xl overflow-hidden shadow-2xl border border-gray-200/50 dark:border-white/10 transition-all duration-500 hover:scale-[1.02] hover:shadow-blue-500/5">
          <!-- Window Header bar -->
          <div class="bg-gray-100/80 dark:bg-slate-800/80 px-4 py-3 flex items-center justify-between border-b border-gray-200/50 dark:border-white/5">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="w-3/5 h-6 bg-gray-200/60 dark:bg-slate-700/50 rounded-lg flex items-center px-3 justify-center">
              <div class="text-[10px] text-gray-400 dark:text-slate-400 font-mono truncate">altamaquina.com</div>
            </div>
            <div class="w-6"></div>
          </div>
          
          <!-- Simulated Interactive Page Content inside mockup -->
          <div class="p-6 space-y-6 min-h-[300px] bg-gradient-to-br from-blue-50/30 to-indigo-50/20 dark:from-slate-950 dark:to-indigo-950/20">
            <div class="space-y-2">
              <div class="h-3 bg-blue-500/30 rounded w-1/4 animate-pulse"></div>
              <div class="h-6 bg-gray-800 dark:bg-white rounded w-3/4"></div>
              <div class="h-6 bg-gray-800 dark:bg-white rounded w-1/2"></div>
            </div>

            <!-- Simulated Cards in Mockup -->
            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/80 dark:bg-slate-800/80 p-3 rounded-xl border border-gray-200/50 dark:border-white/5 shadow-sm space-y-2">
                <div class="w-6 h-6 rounded bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600">
                  <IconDeviceLaptop className="w-3.5 h-3.5" />
                </div>
                <div class="h-2 bg-gray-300 dark:bg-slate-700 rounded w-2/3"></div>
                <div class="h-1.5 bg-gray-200 dark:bg-slate-700/50 rounded w-full"></div>
              </div>
              <div class="bg-white/80 dark:bg-slate-800/80 p-3 rounded-xl border border-gray-200/50 dark:border-white/5 shadow-sm space-y-2">
                <div class="w-6 h-6 rounded bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-purple-600">
                  <Icons.IconShoppingCart className="w-3.5 h-3.5" />
                </div>
                <div class="h-2 bg-gray-300 dark:bg-slate-700 rounded w-2/3"></div>
                <div class="h-1.5 bg-gray-200 dark:bg-slate-700/50 rounded w-full"></div>
              </div>
            </div>

            <!-- Mini stats mockup in browser -->
            <div class="p-3 bg-blue-600 rounded-xl text-white flex justify-between items-center shadow-lg shadow-blue-600/10">
              <div class="space-y-1">
                <span class="text-[9px] uppercase tracking-wider text-blue-100 block">Ventas este mes</span>
                <span class="text-sm font-bold">$148.900</span>
              </div>
              <div class="w-10 h-6 bg-white/20 rounded flex items-end justify-between p-1">
                <div class="w-1.5 h-3 bg-white/60 rounded-t"></div>
                <div class="w-1.5 h-4 bg-white/80 rounded-t"></div>
                <div class="w-1.5 h-2 bg-white/40 rounded-t"></div>
                <div class="w-1.5 h-5 bg-white rounded-t"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
