---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import SocialLinks from '../ui/SocialLinks.astro';
import * as Icons from '@tabler/icons-react';
import { nombreContacto } from '../../data/social';
---

<section id="contacto" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg">
  <Container>
    <SectionTitle
      title="¿Necesitás servicio técnico?"
      highlight="servicio técnico"
      subtitle="Contactanos y coordinamos la revisión de tu equipo"
    />

    <div class="max-w-xl mx-auto">
      <div class="relative bg-white dark:bg-dark-bg-secondary border border-gray-200 dark:border-dark-border rounded-2xl p-8 sm:p-12">
        <div class="flex flex-col items-center text-center">
          {/* Avatar */}
          <div class="flex items-center justify-center w-20 h-20 rounded-full bg-emerald-500/10 dark:bg-emerald-400/20 border border-emerald-500/20 dark:border-emerald-400/30 mb-6">
            <Icons.IconUser className="w-10 h-10 text-emerald-600 dark:text-emerald-400" />
          </div>

          {/* Name */}
          <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-2">
            {nombreContacto}
          </h3>
          <p class="text-sm text-gray-500 dark:text-dark-text-secondary mb-8">
            Servicio técnico de PC
          </p>

          {/* Social links */}
          <div class="w-full max-w-md">
            <SocialLinks showName={true} size="md" layout="grid" />
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
