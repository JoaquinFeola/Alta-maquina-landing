---
interface Props {
  title: string;
  highlight?: string;  // The word(s) to highlight with accent color
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, highlight, subtitle, align = 'center' } = Astro.props;

// If highlight is provided, split the title around it
let beforeHighlight = '';
let afterHighlight = '';
if (highlight) {
  const parts = title.split(highlight);
  beforeHighlight = parts[0] || '';
  afterHighlight = parts[1] || '';
}
---

<div class:list={[
  'mb-16',
  align === 'center' ? 'text-center' : 'text-left',
]}>
  <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-dark-text mb-4">
    {highlight ? (
      <>
        {beforeHighlight}
        <span class="text-primary dark:text-accent">{highlight}</span>
        {afterHighlight}
      </>
    ) : (
      title
    )}
  </h2>
  {subtitle && (
    <p class="text-lg text-gray-500 dark:text-dark-text-secondary max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
