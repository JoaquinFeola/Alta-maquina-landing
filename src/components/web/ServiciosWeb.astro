---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import {
  IconLayout,
  IconBuilding,
  IconShoppingCart,
  IconCalendar,
  IconGridDots,
  IconCode,
} from '@tabler/icons-react';
import { serviciosWeb } from '../../data/servicios-web';

const iconMap: Record<string, any> = {
  'IconLayout': IconLayout,
  'IconBuilding': IconBuilding,
  'IconShoppingCart': IconShoppingCart,
  'IconCalendar': IconCalendar,
  'IconGridDots': IconGridDots,
  'IconCode': IconCode,
};
---

<section id="servicios" class="relative py-20 lg:py-32 bg-slate-50 dark:bg-slate-900/40 overflow-hidden">
  <!-- Decorative glowing shape -->
  <div class="absolute bottom-[-10%] left-[-10%] w-[35vw] h-[35vw] rounded-full bg-blue-500/5 dark:bg-blue-500/5 blur-3xl animate-float-slow"></div>

  <Container class="relative z-10">
    <SectionTitle
      title="Nuestros servicios"
      highlight="servicios"
      subtitle="Soluciones digitales a medida diseñadas para potenciar las ventas y la presencia online de tu negocio."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto">
      {serviciosWeb.map((servicio) => {
        const IconComponent = iconMap[servicio.icono];
        return (
          <div class="group relative glass-card rounded-2xl p-6 sm:p-8 shadow-sm flex flex-col justify-between hover:shadow-xl hover:-translate-y-1 hover:border-blue-500/30 dark:hover:border-blue-400/30 overflow-hidden glow-card">
            <div>
              <!-- Icon Container -->
              <div class="flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-600/10 dark:bg-blue-400/10 text-blue-600 dark:text-blue-400 mb-6 transition-all duration-300 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white shadow-inner">
                {IconComponent && <IconComponent className="w-7 h-7" />}
              </div>

              <!-- Title -->
              <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">
                {servicio.titulo}
              </h3>

              <!-- Description -->
              <p class="text-sm text-gray-600 dark:text-dark-text-secondary leading-relaxed mb-6">
                {servicio.descripcion}
              </p>
            </div>

            <!-- Arrow Link indicator -->
            <div class="flex items-center text-xs font-semibold text-blue-600 dark:text-blue-400 group-hover:translate-x-1.5 transition-transform duration-300 gap-1 mt-auto">
              <span>Saber más</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>

            <!-- Bottom decorative gradient line -->
            <div class="absolute bottom-0 left-0 right-0 h-[3px] bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        );
      })}
    </div>
  </Container>
</section>
