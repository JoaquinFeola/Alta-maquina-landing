---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import * as Icons from '@tabler/icons-react';
import { planesWeb, planesMantenimiento, extras } from '../../data/planes';

const iconMap: Record<string, any> = {
  'IconPackage': Icons.IconPackage,
  'IconWorld': Icons.IconWorld,
  'IconCalendar': Icons.IconCalendar,
  'IconShoppingCart': Icons.IconShoppingCart,
  'IconBolt': Icons.IconBolt,
};
---

<section id="planes" class="relative py-20 lg:py-32 bg-white dark:bg-dark-bg">
  <Container>
    <SectionTitle
      title="Nuestros planes"
      highlight="planes"
      subtitle="Elegí el plan ideal para tu negocio. Todos incluyen diseño responsive y optimización para Google"
    />

    <!-- Tab buttons -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button class="tab-btn active px-6 py-3 rounded-full text-sm font-medium transition-all duration-300" data-tab="desarrollo">
        Desarrollo Web
      </button>
      <button class="tab-btn px-6 py-3 rounded-full text-sm font-medium transition-all duration-300" data-tab="mantenimiento">
        Mantenimiento
      </button>
      <button class="tab-btn px-6 py-3 rounded-full text-sm font-medium transition-all duration-300" data-tab="extras">
        Extras
      </button>
    </div>

    <!-- Tab: Desarrollo Web -->
    <div class="tab-content active" id="tab-desarrollo">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {planesWeb.map((plan) => {
          const PlanIcon = iconMap[plan.icono];
          return (
            <div class={`group relative bg-white dark:bg-dark-bg-secondary border-2 rounded-2xl p-6 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 ${plan.popular ? 'border-primary dark:border-accent' : 'border-gray-200 dark:border-dark-border hover:border-primary/50 dark:hover:border-accent/50'}`}>
              {/* Popular badge */}
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1 px-4 py-1 rounded-full text-xs font-semibold bg-primary dark:bg-accent text-white">
                    <Icons.IconStar className="w-3 h-3" />
                    Popular
                  </span>
                </div>
              )}

              {/* Icon + Name */}
              <div class="flex items-center gap-3 mb-4">
                <div class={`p-2.5 rounded-xl ${plan.popular ? 'bg-primary/10 dark:bg-accent/15 text-primary dark:text-accent' : 'bg-gray-100 dark:bg-dark-bg text-gray-500 dark:text-dark-text-secondary'}`}>
                  {PlanIcon && <PlanIcon className="w-5 h-5" />}
                </div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-dark-text">{plan.nombre}</h3>
              </div>

              {/* Price */}
              <div class="mb-4">
                <span class="text-2xl sm:text-3xl font-bold text-primary dark:text-accent">{plan.precio}</span>
              </div>

              {/* Description */}
              <p class="text-sm text-gray-500 dark:text-dark-text-secondary mb-5">{plan.descripcion}</p>

              {/* Incluye */}
              <div class="mb-4">
                <h4 class="text-xs font-semibold text-gray-900 dark:text-dark-text mb-2 uppercase tracking-wider">Incluye</h4>
                <ul class="space-y-1.5">
                  {plan.incluye.map((item) => (
                    <li class="text-sm text-gray-600 dark:text-dark-text-secondary flex items-start gap-2">
                      <Icons.IconCheck className="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              {/* No incluye */}
              {plan.noIncluye && plan.noIncluye.length > 0 && (
                <div class="mb-4 pt-4 border-t border-gray-100 dark:border-dark-border">
                  <h4 class="text-xs font-semibold text-gray-900 dark:text-dark-text mb-2 uppercase tracking-wider">No incluye</h4>
                  <ul class="space-y-1.5">
                    {plan.noIncluye.map((item) => (
                      <li class="text-sm text-gray-400 dark:text-gray-500 flex items-start gap-2">
                        <Icons.IconX className="w-4 h-4 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Note */}
              {plan.nota && (
                <p class="text-xs text-gray-400 dark:text-gray-500 italic mt-4 pt-4 border-t border-gray-100 dark:border-dark-border">
                  * {plan.nota}
                </p>
              )}

              {/* Examples */}
              {plan.ejemplos && (
                <div class="mt-4 pt-4 border-t border-gray-100 dark:border-dark-border">
                  <p class="text-xs text-gray-500 dark:text-dark-text-secondary mb-2">Ejemplos de páginas:</p>
                  <div class="flex flex-wrap gap-1.5">
                    {plan.ejemplos.map((ej) => (
                      <span class="px-2 py-0.5 text-xs rounded-md bg-gray-100 dark:bg-dark-bg text-gray-600 dark:text-dark-text-secondary">
                        {ej}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Tab: Mantenimiento -->
    <div class="tab-content hidden" id="tab-mantenimiento">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
          {planesMantenimiento.map((plan) => (
            <div class="group relative bg-white dark:bg-dark-bg-secondary border-2 border-gray-200 dark:border-dark-border rounded-2xl p-6 transition-all duration-300 hover:border-primary/50 dark:hover:border-accent/50 hover:shadow-xl hover:-translate-y-1">
              <h3 class="text-xl font-bold text-gray-900 dark:text-dark-text mb-2">{plan.nombre}</h3>
              <span class="text-2xl sm:text-3xl font-bold text-primary dark:text-accent">{plan.precio}</span>
              <p class="text-sm text-gray-500 dark:text-dark-text-secondary mt-2 mb-5">{plan.descripcion}</p>

              <div class="mb-4">
                <h4 class="text-xs font-semibold text-gray-900 dark:text-dark-text mb-2 uppercase tracking-wider">Incluye</h4>
                <ul class="space-y-1.5">
                  {plan.incluye.map((item) => (
                    <li class="text-sm text-gray-600 dark:text-dark-text-secondary flex items-start gap-2">
                      <Icons.IconCheck className="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              {plan.noIncluye && plan.noIncluye.length > 0 && (
                <div class="pt-4 border-t border-gray-100 dark:border-dark-border">
                  <h4 class="text-xs font-semibold text-gray-900 dark:text-dark-text mb-2 uppercase tracking-wider">No incluye</h4>
                  <ul class="space-y-1.5">
                    {plan.noIncluye.map((item) => (
                      <li class="text-sm text-gray-400 dark:text-gray-500 flex items-start gap-2">
                        <Icons.IconX className="w-4 h-4 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Tab: Extras -->
    <div class="tab-content hidden" id="tab-extras">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-dark-bg-secondary border-2 border-gray-200 dark:border-dark-border rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-6 text-center">Servicios Extra</h3>
          <div class="space-y-3">
            {extras.map((extra) => (
              <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-dark-bg rounded-xl">
                <span class="text-gray-900 dark:text-dark-text font-medium text-sm">{extra.servicio}</span>
                <span class="text-primary dark:text-accent font-bold text-sm">{extra.precio}</span>
              </div>
            ))}
          </div>
          <p class="text-sm text-gray-500 dark:text-dark-text-secondary text-center mt-6">
            ¿Necesitás algo que no está en la lista? Contactanos y te cotizamos
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  function setActiveTab(tabId: string) {
    tabBtns.forEach((btn) => {
      const isActive = btn.getAttribute('data-tab') === tabId;
      btn.classList.toggle('bg-primary', isActive);
      btn.classList.toggle('dark:bg-accent', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('bg-gray-100', !isActive);
      btn.classList.toggle('dark:bg-dark-bg-secondary', !isActive);
      btn.classList.toggle('text-gray-600', !isActive);
      btn.classList.toggle('dark:text-dark-text-secondary', !isActive);
    });

    tabContents.forEach((content) => {
      const el = content as HTMLElement;
      el.classList.toggle('hidden', el.id !== `tab-${tabId}`);
      el.classList.toggle('active', el.id === `tab-${tabId}`);
    });
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');
      if (tabId) setActiveTab(tabId);
    });
  });

  // Initialize first tab
  setActiveTab('desarrollo');
</script>

<style>
  .tab-content.active {
    display: block;
  }
  .tab-content.hidden {
    display: none;
  }
</style>
