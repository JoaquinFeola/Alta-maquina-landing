---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import {
  IconLayout,
  IconBuilding,
  IconShoppingCart,
  IconCalendar,
  IconGridDots,
  IconCode,
} from '@tabler/icons-react';
import { serviciosWeb } from '../../data/servicios-web';

const iconMap: Record<string, any> = {
  'IconLayout': IconLayout,
  'IconBuilding': IconBuilding,
  'IconShoppingCart': IconShoppingCart,
  'IconCalendar': IconCalendar,
  'IconGridDots': IconGridDots,
  'IconCode': IconCode,
};
---

<section id="servicios" class="relative py-20 lg:py-32 bg-gray-50 dark:bg-dark-bg">
  <Container>
    <SectionTitle
      title="Nuestros servicios"
      highlight="servicios"
      subtitle="Soluciones digitales para que tu negocio crezca online"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 max-w-6xl mx-auto">
      {serviciosWeb.map((servicio) => {
        const IconComponent = iconMap[servicio.icono];
        return (
          <div class="group relative bg-white dark:bg-dark-bg-secondary border border-gray-200 dark:border-dark-border rounded-2xl p-6 sm:p-8 transition-all duration-300 hover:border-primary/40 dark:hover:border-accent/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5 dark:hover:shadow-accent/5">
            {/* Icon */}
            <div class="flex items-center justify-center w-14 h-14 rounded-xl bg-primary/10 dark:bg-accent/15 text-primary dark:text-accent mb-5 transition-transform duration-300 group-hover:scale-110">
              {IconComponent && <IconComponent className="w-7 h-7" />}
            </div>

            {/* Title */}
            <h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-dark-text mb-3">
              {servicio.titulo}
            </h3>

            {/* Description */}
            <p class="text-sm text-gray-500 dark:text-dark-text-secondary leading-relaxed">
              {servicio.descripcion}
            </p>

            {/* Bottom accent line on hover */}
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-gradient-to-r from-primary to-accent dark:from-accent dark:to-primary transition-all duration-300 group-hover:w-3/4 rounded-full"></div>
          </div>
        );
      })}
    </div>
  </Container>
</section>
