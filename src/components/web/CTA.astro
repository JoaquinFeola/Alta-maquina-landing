---
import Container from '../Container.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import SocialLinks from '../ui/SocialLinks.astro';
import * as Icons from '@tabler/icons-react';
import { nombreContacto } from '../../data/social';
---

<section id="contacto" class="relative py-20 lg:py-32 bg-white dark:bg-dark-bg">
  <Container>
    <SectionTitle
      title="¿Listo para potenciar tu negocio?"
      highlight="potenciar"
      subtitle="Elegí cómo contactarnos y empecemos a crear tu presencia online"
    />

    <div class="max-w-xl mx-auto">
      <div class="relative bg-gradient-to-br from-primary/5 via-white to-accent/5 dark:from-accent/5 dark:via-dark-bg-secondary dark:to-primary/5 border border-gray-200 dark:border-dark-border rounded-2xl p-8 sm:p-12">
        {/* Content */}
        <div class="flex flex-col items-center text-center">
          {/* Avatar */}
          <div class="flex items-center justify-center w-20 h-20 rounded-full bg-primary/10 dark:bg-accent/20 border border-primary/20 dark:border-accent/30 mb-6">
            <Icons.IconUser className="w-10 h-10 text-primary dark:text-accent" />
          </div>

          {/* Name */}
          <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-2">
            {nombreContacto}
          </h3>
          <p class="text-sm text-gray-500 dark:text-dark-text-secondary mb-8">
            Desarrollador web
          </p>

          {/* Social links */}
          <div class="w-full max-w-md">
            <SocialLinks showName={true} size="md" layout="grid" />
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
