---
import Container from "../Container.astro";
import Button from "../Button.astro";
import { Image } from "astro:assets";
import PCHeroImage from "../../assets/images/pc_hero.webp";
import * as Icons from '@tabler/icons-react';

const { IconSparkles, IconShieldCheck, IconTools } = Icons;
---

<section id="hero" class="relative min-h-[85vh] flex items-center justify-center overflow-hidden pt-20">
  <!-- Glowing Background Orbs & Gradients (Wow Factor) -->
  <div class="absolute inset-0 bg-gradient-to-b from-blue-50/40 via-white to-gray-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.05)_1px,transparent_1px)] bg-[size:32px_32px] dark:bg-[linear-gradient(rgba(59,130,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.03)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_at_center,white,transparent_80%)]"></div>

    <!-- Animated Orbs -->
    <div class="absolute top-[-10%] right-[-10%] w-[45vw] h-[45vw] rounded-full bg-cyan-600/10 dark:bg-cyan-600/15 blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[45vw] h-[45vw] rounded-full bg-blue-600/10 dark:bg-blue-600/15 blur-3xl animate-float-slower"></div>

    <!-- Background image (blurred, optimized — overlay) -->
    <div class="absolute inset-0 z-0 opacity-20 dark:opacity-10 pointer-events-none">
      <Image
        class="w-full h-full object-cover"
        src={PCHeroImage}
        alt="Servicio técnico de computadoras"
        width={1280}
        height={720}
        quality={40}
        sizes="100vw"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />
      <!-- Blur overlay -->
      <div class="absolute inset-0 backdrop-blur-[6px]"></div>
    </div>
  </div>

  <Container class="relative z-10 py-12 lg:py-20">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <!-- Interactive Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border border-gray-200/85 dark:border-white/10 shadow-lg mb-2 hover:scale-[1.02] transition-transform duration-200 cursor-default">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue-600 dark:bg-blue-400"></span>
        </span>
        <span class="text-xs text-gray-700 dark:text-white/95 font-semibold flex items-center gap-1.5">
          Servicio Técnico en Partido de la Costa <IconSparkles className="w-3.5 h-3.5 text-blue-500" />
        </span>
      </div>

      <!-- Main Heading -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight text-gray-900 dark:text-white leading-tight">
        Tu PC funcionando<br />
        como <span class="text-gradient-cyan">el primer día.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-gray-600 dark:text-dark-text-secondary leading-relaxed max-w-2xl mx-auto">
        Limpieza física profunda, diagnóstico preciso y armado de computadoras a medida en <span class="text-gray-900 dark:text-white font-semibold">San Bernardo</span> y todo el Partido de la Costa.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <Button variant="primary" href="#servicios" class="w-full sm:w-auto shadow-lg shadow-blue-500/20 hover:shadow-blue-500/35 hover:scale-[1.03] transition-all">
          Ver servicios técnicos <IconTools class="ml-2 w-4 h-4 inline" />
        </Button>
        <Button variant="secondary" href="#contacto" class="w-full sm:w-auto glass hover:bg-gray-100 dark:hover:bg-white/10 hover:scale-[1.03] transition-all">
          Coordinar servicio
        </Button>
      </div>

      <!-- Trust Badges (Conversion Boosters) -->
      <div class="pt-12 border-t border-gray-200/50 dark:border-white/5 flex flex-wrap justify-center gap-x-12 gap-y-6 max-w-2xl mx-auto">
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-slate-350">
          <IconShieldCheck className="w-5 h-5 text-blue-500 flex-shrink-0" />
          <span>Garantía de servicio</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-slate-350">
          <IconSparkles className="w-5 h-5 text-blue-500 flex-shrink-0" />
          <span>Componentes de calidad</span>
        </div>
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-slate-350">
          <Icons.IconHourglassHigh className="w-5 h-5 text-blue-500 flex-shrink-0" />
          <span>Limpieza en el día</span>
        </div>
      </div>
    </div>
  </Container>
</section>
