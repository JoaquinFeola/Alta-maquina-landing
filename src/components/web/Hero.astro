---
import Container from '../Container.astro';
import Button from '../Button.astro';
---

<section id="hero" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-blue-50/30 dark:from-slate-900 dark:via-slate-900 dark:to-indigo-950/50">
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.06)_1px,transparent_1px)] bg-[size:40px_40px] dark:bg-[linear-gradient(rgba(99,102,241,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(99,102,241,0.06)_1px,transparent_1px)]"></div>

    <!-- Accent gradients (subtle) -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_rgba(59,130,246,0.15)_0%,_transparent_50%)] dark:bg-[radial-gradient(ellipse_at_top_left,_rgba(59,130,246,0.2)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_rgba(139,92,246,0.1)_0%,_transparent_50%)] dark:bg-[radial-gradient(ellipse_at_bottom_right,_rgba(139,92,246,0.15)_0%,_transparent_50%)]"></div>

    <!-- Floating elements -->
    <div class="absolute top-20 left-10 w-32 h-32 bg-blue-500/10 rounded-2xl rotate-12 blur-xl"></div>
    <div class="absolute bottom-20 right-10 w-28 h-28 bg-purple-500/10 rounded-2xl -rotate-12 blur-xl"></div>

    <!-- Background image (blurred) -->
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1920&q=80" 
        alt="Desarrollo web profesional" 
        class="w-full h-full object-cover opacity-30 dark:opacity-20"
        loading="eager"
      />
      <!-- Blur overlay -->
      <div class="absolute inset-0 backdrop-blur-[8px]"></div>
    </div>
  </div>

  <!-- Browser mockup (xl only) -->
  <div class="absolute right-8 top-1/2 -translate-y-1/2 w-[40%] max-w-lg hidden xl:block">
    <div class="relative">
      <div class="absolute -inset-4 bg-gradient-to-r from-blue-600/10 via-purple-600/10 to-pink-600/10 rounded-2xl blur-2xl"></div>
      <div class="relative bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-2xl border border-gray-200 dark:border-white/10">
        <!-- Browser header -->
        <div class="bg-gray-100 dark:bg-gray-800/80 px-4 py-2.5 flex items-center gap-2">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/80"></div>
          </div>
          <div class="flex-1 mx-4">
            <div class="h-6 bg-gray-200 dark:bg-gray-700/50 rounded-md flex items-center px-3">
              <div class="w-2/3 h-2 bg-gray-300 dark:bg-gray-600/50 rounded-full"></div>
            </div>
          </div>
        </div>
        <!-- Browser content mockup -->
        <div class="p-6 bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-indigo-900/50 dark:to-purple-900/50 min-h-[180px]">
          <div class="space-y-3">
            <div class="h-3 bg-blue-200 dark:bg-blue-500/20 rounded w-1/2"></div>
            <div class="h-5 bg-gray-300 dark:bg-white/10 rounded w-3/4"></div>
            <div class="h-5 bg-gray-300 dark:bg-white/10 rounded w-1/2"></div>
            <div class="flex gap-3 mt-4">
              <div class="h-16 w-1/3 bg-gradient-to-br from-blue-200 to-blue-300 dark:from-blue-500/20 dark:to-blue-400/20 rounded-lg"></div>
              <div class="h-16 w-1/3 bg-gradient-to-br from-purple-200 to-pink-200 dark:from-purple-500/20 dark:to-pink-400/20 rounded-lg"></div>
              <div class="h-16 w-1/3 bg-gradient-to-br from-indigo-200 to-blue-200 dark:from-indigo-500/20 dark:to-blue-400/20 rounded-lg"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <Container class="relative z-10 py-20">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 dark:bg-white/10 backdrop-blur-md border border-gray-200 dark:border-white/20 shadow-sm mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
        </span>
        <span class="text-sm text-gray-600 dark:text-white/80 font-medium">Desarrollo Web Profesional</span>
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
        Potenciá tu negocio.<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-purple-600 to-pink-500 dark:from-blue-400 dark:via-purple-400 dark:to-pink-400">Conquistá internet.</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-gray-600 dark:text-white/70 mb-10 max-w-2xl mx-auto leading-relaxed">
        Desarrollo web profesional: landing pages, tiendas online, sistemas de turnos y más. <span class="text-gray-900 dark:text-white font-medium">Todo lo que necesitás para crecer online.</span>
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <Button variant="primary" href="#planes">
          Ver planes
        </Button>
        <Button variant="secondary" href="#contacto">
          Contactanos
        </Button>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 flex justify-center">
        <div class="flex flex-col items-center gap-2 group cursor-pointer">
          <span class="text-xs uppercase tracking-widest text-gray-400 dark:text-white/40 group-hover:text-gray-600 dark:group-hover:text-white/70 transition-colors">Scroll</span>
          <div class="w-6 h-10 rounded-full border-2 border-gray-300 dark:border-white/20 group-hover:border-gray-400 dark:group-hover:border-white/40 transition-colors flex justify-center pt-2">
            <div class="w-1.5 h-3 rounded-full bg-gray-400 dark:bg-white/30 group-hover:bg-gray-600 dark:group-hover:bg-white/60 transition-colors animate-bounce"></div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
