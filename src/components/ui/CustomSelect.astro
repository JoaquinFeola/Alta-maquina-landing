---
import * as Icons from '@tabler/icons-react';

interface Option {
  value: string;
  label: string;
}

interface Props {
  id: string;
  name: string;
  label?: string;
  options: Option[];
  placeholder?: string;
  class?: string;
}

const {
  id,
  name,
  label,
  options,
  placeholder = "Seleccionar una opción",
  class: className = ""
} = Astro.props;

const { IconChevronDown, IconCheck } = Icons;
---

<div class={`custom-select-wrapper ${className}`}>
  {label && (
    <label for={id} class="block text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-slate-450 mb-1.5">
      {label}
    </label>
  )}
  
  <div class="relative">
    <!-- Hidden native select for form submission -->
    <select id={id} name={name} class="native-select sr-only" tabindex="-1" aria-hidden="true">
      <option value="">{placeholder}</option>
      {options.map(opt => (
        <option value={opt.value}>{opt.label}</option>
      ))}
    </select>

    <!-- Custom trigger -->
    <button
      type="button"
      id={`${id}-trigger`}
      class="custom-select-trigger w-full px-4 py-3.5 rounded-xl border border-gray-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-950/40 text-left text-gray-900 dark:text-white flex items-center justify-between gap-2 transition-all focus:outline-none focus:ring-2 focus:ring-blue-500/50 dark:focus:ring-blue-400/50 focus:border-blue-500 text-sm font-medium"
    >
      <span class="selected-text text-gray-400 dark:text-slate-500 truncate">
        {placeholder}
      </span>
      <IconChevronDown className="w-5 h-5 text-gray-450 dark:text-slate-500 transition-transform duration-200 chevron-icon flex-shrink-0" />
    </button>

    <!-- Custom dropdown -->
    <div
      id={`${id}-dropdown`}
      class="custom-select-dropdown absolute z-50 mt-2 w-full bg-white dark:bg-slate-900 border border-gray-200 dark:border-white/10 rounded-2xl shadow-2xl overflow-hidden hidden"
    >
      <div class="max-h-60 overflow-y-auto py-1">
        {options.map((opt, index) => (
          <button
            type="button"
            data-value={opt.value}
            data-label={opt.label}
            class={`custom-select-option w-full px-4 py-3 text-left text-gray-900 dark:text-white hover:bg-slate-50 dark:hover:bg-white/5 transition-colors flex items-center justify-between gap-2 group text-sm font-medium ${index === 0 ? 'rounded-t-2xl' : ''} ${index === options.length - 1 ? 'rounded-b-2xl' : ''}`}
          >
            <span class="truncate">{opt.label}</span>
            <IconCheck className="w-4 h-4 text-blue-600 dark:text-blue-400 opacity-0 check-icon transition-opacity" />
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  function initCustomSelects() {
    document.querySelectorAll('.custom-select-wrapper').forEach((wrapper) => {
      const trigger = wrapper.querySelector('.custom-select-trigger') as HTMLButtonElement | null;
      const dropdown = wrapper.querySelector('.custom-select-dropdown') as HTMLDivElement | null;
      const selectedText = wrapper.querySelector('.selected-text');
      const chevron = trigger ? (trigger.querySelector('.chevron-icon') || trigger.querySelector('svg')) as HTMLElement | null : null;
      const nativeSelect = wrapper.querySelector('.native-select') as HTMLSelectElement | null;

      if (!trigger || !dropdown) return;

      let isOpen = false;

      function openDropdown() {
        if (!dropdown || !trigger) return;
        isOpen = true;
        dropdown.classList.remove('hidden');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        trigger.classList.add('ring-2', 'ring-blue-500/50', 'dark:ring-blue-400/50', 'border-blue-500');
        trigger.setAttribute('aria-expanded', 'true');
      }

      function closeDropdown() {
        if (!dropdown || !trigger) return;
        isOpen = false;
        dropdown.classList.add('hidden');
        if (chevron) chevron.style.transform = 'rotate(0deg)';
        trigger.classList.remove('ring-2', 'ring-blue-500/50', 'dark:ring-blue-400/50', 'border-blue-500');
        trigger.setAttribute('aria-expanded', 'false');
      }

      function selectOption(value: string, label: string) {
        if (!selectedText || !nativeSelect || !dropdown || !trigger) return;

        nativeSelect.value = value;
        // Dispatch event so forms can listen to changes
        nativeSelect.dispatchEvent(new Event('change', { bubbles: true }));
        
        selectedText.textContent = label;
        selectedText.classList.remove('text-gray-400', 'dark:text-slate-500');
        selectedText.classList.add('text-gray-900', 'dark:text-white');

        dropdown.querySelectorAll('.custom-select-option').forEach(opt => {
          const check = opt.querySelector('.check-icon') || opt.querySelector('svg');
          const optValue = opt.getAttribute('data-value');
          if (optValue === value) {
            opt.classList.add('bg-slate-55', 'dark:bg-white/5');
            check?.classList.remove('opacity-0');
            check?.classList.add('opacity-100');
          } else {
            opt.classList.remove('bg-slate-55', 'dark:bg-white/5');
            check?.classList.remove('opacity-100');
            check?.classList.add('opacity-0');
          }
        });

        closeDropdown();
      }

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        if (isOpen) {
          closeDropdown();
        } else {
          openDropdown();
        }
      });

      dropdown.querySelectorAll('.custom-select-option').forEach(option => {
        option.addEventListener('click', (e) => {
          e.stopPropagation();
          const value = option.getAttribute('data-value');
          const label = option.getAttribute('data-label');
          if (value && label) {
            selectOption(value, label);
          }
        });
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) {
          closeDropdown();
        }
      });

      document.addEventListener('click', (e) => {
        if (isOpen && !trigger.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
          closeDropdown();
        }
      });

      // Sync initial state if value exists
      if (nativeSelect && nativeSelect.value) {
        const selectedOption = dropdown.querySelector(`[data-value="${nativeSelect.value}"]`);
        if (selectedOption) {
          const label = selectedOption.getAttribute('data-label');
          if (label && selectedText) {
            selectedText.textContent = label;
            selectedText.classList.remove('text-gray-450', 'dark:text-slate-500');
            selectedText.classList.add('text-gray-900', 'dark:text-white');
          }
        }
      }
    });
  }

  // Initialize
  initCustomSelects();
  document.addEventListener('astro:page-load', initCustomSelects);
</script>

<style>
  .custom-select-dropdown {
    animation: dropdownFadeIn 150ms ease-out;
  }

  @keyframes dropdownFadeIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scrollbar styling for dropdown */
  .custom-select-dropdown::-webkit-scrollbar {
    width: 6px;
  }

  .custom-select-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }

  .custom-select-dropdown::-webkit-scrollbar-thumb {
    background-color: #d1d5db;
    border-radius: 3px;
  }

  .dark .custom-select-dropdown::-webkit-scrollbar-thumb {
    background-color: #475569;
  }
</style>