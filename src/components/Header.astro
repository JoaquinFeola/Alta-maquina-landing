---
import Container from './Container.astro';
import * as Icons from '@tabler/icons-react';

const { IconSun, IconMoon, IconMenu2 } = Icons;
---

<script>
  const menuButton = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function toggleMenu() {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
  }

  menuButton?.addEventListener('click', toggleMenu);

  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    });
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const themeToggleMobile = document.getElementById('theme-toggle-mobile');

  function toggleTheme() {
    const html = document.documentElement;
    const isDark = html.classList.contains('dark');

    if (isDark) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  }

  themeToggle?.addEventListener('click', toggleTheme);
  themeToggleMobile?.addEventListener('click', toggleTheme);
</script>

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 dark:bg-dark-bg/90 backdrop-blur-md border-b border-gray-200 dark:border-dark-border">
  <Container>
    <nav class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity">
        <img src="/favicon.svg" alt="Alta Maquina" class="w-10 h-10 rounded-full object-cover" />
        <span class="ml-3 text-lg font-bold text-gray-900 dark:text-dark-text">Alta Maquina</span>
      </a>
      
      <!-- Desktop Navigation -->
      <ul class="hidden md:flex items-center gap-8">
        <li>
          <a href="#servicios" class="text-sm text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Servicios
          </a>
        </li>
        <li>
          <a href="#planes" class="text-sm text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Planes
          </a>
        </li>
        <li>
          <a href="#por-que-elegirnos" class="text-sm text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Nosotros
          </a>
        </li>
        <li>
          <a href="#contacto" class="text-sm text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Contacto
          </a>
        </li>
        <li>
          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            type="button"
            class="p-2 text-gray-500 dark:text-dark-text-secondary hover:text-gray-900 dark:hover:text-dark-text bg-gray-100 dark:bg-dark-bg-secondary hover:bg-gray-200 dark:hover:bg-slate-700 rounded-lg transition-all duration-200 focus:outline-none"
            aria-label="Cambiar tema"
          >
            <IconMoon className="w-5 h-5 dark:hidden" />
            <IconSun className="w-5 h-5 hidden dark:block" />
          </button>
        </li>
      </ul>

      <!-- Mobile Menu Button -->
      <button 
        id="menu-toggle" 
        type="button" 
        class="md:hidden p-2 text-gray-500 dark:text-dark-text-secondary hover:text-gray-900 dark:hover:text-dark-text focus:outline-none"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <IconMenu2 className="w-6 h-6" />
      </button>
    </nav>
  </Container>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 dark:bg-dark-bg/95 backdrop-blur-md border-b border-gray-200 dark:border-dark-border">
    <Container>
      <ul class="py-4 space-y-4">
        <li>
          <a href="#servicios" class="mobile-link block text-base text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Servicios
          </a>
        </li>
        <li>
          <a href="#planes" class="mobile-link block text-base text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Planes
          </a>
        </li>
        <li>
          <a href="#por-que-elegirnos" class="mobile-link block text-base text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Nosotros
          </a>
        </li>
        <li>
          <a href="#contacto" class="mobile-link block text-base text-gray-500 dark:text-dark-text-secondary hover:text-primary dark:hover:text-accent transition-colors">
            Contacto
          </a>
        </li>
        <li>
          <!-- Theme Toggle Button (Mobile) -->
          <button
            id="theme-toggle-mobile"
            type="button"
            class="p-2 text-gray-500 dark:text-dark-text-secondary hover:text-gray-900 dark:hover:text-dark-text bg-gray-100 dark:bg-dark-bg-secondary hover:bg-gray-200 dark:hover:bg-slate-700 rounded-lg transition-all duration-200 focus:outline-none"
            aria-label="Cambiar tema"
          >
            <IconMoon className="w-5 h-5 dark:hidden" />
            <IconSun className="w-5 h-5 hidden dark:block" />
          </button>
        </li>
      </ul>
    </Container>
  </div>
</header>