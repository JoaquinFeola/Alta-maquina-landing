---
import "../styles/global.css";

import Container from './Container.astro';
import DesktopNav from './ui/DesktopNav.astro';
import MobileMenu from './ui/MobileMenu.astro';
import * as Icons from '@tabler/icons-react';
import { navLinksWeb, navLinksPC, pcPageLink, webPageLink } from '../data/nav';

interface Props {
  page?: 'web' | 'pc';
}

const { page = 'web' } = Astro.props;

const navLinks = page === 'web' ? navLinksWeb : navLinksPC;
const crossPageLink = page === 'web' ? pcPageLink : webPageLink;
const CrossPageIcon = page === 'web' ? Icons.IconDeviceDesktop : Icons.IconWorld;
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 header-at-top"
>
  <Container>
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center hover:opacity-80 transition-opacity shrink-0">
        <img src="/favicon.svg" alt="Alta Maquina" class="w-10 h-10 rounded-full" />
        <span class="ml-3 text-lg font-bold logo-text">Alta Maquina</span>
      </a>

      <!-- Desktop Navigation -->
      <DesktopNav navLinks={navLinks} crossPageLink={crossPageLink} CrossPageIcon={CrossPageIcon} />

      <!-- Mobile Navigation -->
      <MobileMenu navLinks={navLinks} crossPageLink={crossPageLink} CrossPageIcon={CrossPageIcon} />
    </nav>
  </Container>

  <!-- Scroll gradient line -->
  <div id="header-gradient-line" class="h-0.5 w-full bg-linear-to-r from-blue-500 via-purple-500 to-pink-500 opacity-0 transition-opacity duration-300"></div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('main-header');
  const gradientLine = document.getElementById('header-gradient-line');
  const scrollThreshold = 50;

  function handleScroll() {
    if (window.scrollY < scrollThreshold) {
      header?.classList.remove('header-scrolled');
      header?.classList.add('header-at-top');
      if (gradientLine) gradientLine.style.opacity = '0';
    } else {
      header?.classList.remove('header-at-top');
      header?.classList.add('header-scrolled');
      if (gradientLine) gradientLine.style.opacity = '1';
    }
  }

  handleScroll();
  window.addEventListener('scroll', handleScroll, { passive: true });

  // Scroll Spy - Active nav indicator based on scroll position
  const navLinks = document.querySelectorAll('.nav-link');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const allLinks = [...navLinks, ...mobileLinks];
  const sections = document.querySelectorAll('section[id]');

  function getSectionIds(): string[] {
    return Array.from(sections).map(s => s.getAttribute('id') || '').filter(Boolean);
  }

  function setActiveLink(href: string) {
    allLinks.forEach((link) => {
      if (link instanceof HTMLAnchorElement && link.getAttribute('href') === href) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  // Set first link as active on page load (hero section)
  const sectionIds = getSectionIds();
  if (sectionIds.length > 0) {
    setActiveLink(`#${sectionIds[0]}`);
  }

  // More robust scroll spy using IntersectionObserver
  // Use a larger rootMargin so we catch sections earlier
  const observerOptions = {
    root: null,
    rootMargin: '-10% 0px -80% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        if (id) {
          setActiveLink(`#${id}`);
        }
      }
    });
  }, observerOptions);

  sections.forEach((section) => {
    observer.observe(section);
  });
</script>

<style>
  @reference "../styles/global.css";

  /* At-top state — fully transparent */
  .header-at-top {
    @apply bg-transparent border-b-0;
  }

  .header-at-top .logo-text {
    @apply text-gray-800 dark:text-white;
  }

  .header-at-top .cross-page-badge {
    @apply text-blue-700 dark:text-blue-300;
  }

  /* Scrolled state — glass background */
  .header-scrolled {
    @apply bg-white/90 dark:bg-dark-bg/90 backdrop-blur-md border-b border-gray-200/50 dark:border-white/10;
  }

  .header-scrolled .logo-text {
    @apply text-gray-900 dark:text-dark-text;
  }

  .header-scrolled .cross-page-badge {
    @apply text-blue-600 dark:text-blue-300;
  }

  /* Scroll spy active nav indicator — animated transition */
  .nav-link {
    @apply text-gray-700 dark:text-white/80 transition-colors duration-200;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, #2563eb, #3b82f6);
    border-radius: 1px;
    opacity: 0;
    transition: width 0.3s ease, opacity 0.3s ease;
  }

  .nav-link.active {
    @apply text-primary dark:text-accent;
  }

  .nav-link.active::after {
    width: 100%;
    opacity: 1;
  }

  .nav-link:hover {
    @apply text-blue-600 dark:text-blue-400;
  }

  /* Mobile nav links */
  .mobile-link {
    @apply text-gray-700 dark:text-white/80 transition-colors duration-200;
    position: relative;
  }

  .mobile-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 4px;
    height: 0;
    background: linear-gradient(to bottom, #2563eb, #3b82f6);
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transition: height 0.3s ease, opacity 0.3s ease;
  }

  .mobile-link.active {
    @apply text-primary dark:text-accent;
  }

  .mobile-link.active::after {
    height: 100%;
    opacity: 1;
  }

  .mobile-link:hover {
    @apply text-blue-600 dark:text-blue-400;
  }

  /* Mobile menu button states */
  .mobile-menu-btn {
    @apply text-gray-700 dark:text-white/90;
  }

  /* Mobile menu background */
  .mobile-menu-bg {
    @apply bg-white/95 dark:bg-dark-bg/95 backdrop-blur-md;
  }
</style>