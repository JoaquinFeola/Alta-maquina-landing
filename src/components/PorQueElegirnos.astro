---
import Container from './Container.astro';
import * as Icons from '@tabler/icons-react';

const { IconBolt, IconCircleCheck, IconMapPin } = Icons;

interface Razon {
  id: number;
  titulo: string;
  descripcion: string;
  icono: any;
}

const razones: Razon[] = [
  {
    id: 1,
    titulo: 'Servicio rápido',
    descripcion: 'Nos ocupamos rápido, sin vueltas',
    icono: IconBolt,
  },
  {
    id: 2,
    titulo: 'Profesional',
    descripcion: 'Todo hecho como corresponde',
    icono: IconCircleCheck,
  },
  {
    id: 3,
    titulo: 'Cerca',
    descripcion: 'Estamos para lo que necesites',
    icono: IconMapPin,
  },
];
---

<section id="por-que-elegirnos" class="relative py-20 lg:py-32 bg-white dark:bg-dark-bg">
  <Container>
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-dark-text mb-4">
        ¿Por qué <span class="text-primary dark:text-accent">elegirnos</span>?
      </h2>
      <p class="text-lg text-gray-500 dark:text-dark-text-secondary max-w-2xl mx-auto">
        Tres razones que nos hacen diferentes
      </p>
    </div>

    <!-- Grid de razones -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {razones.map((razon) => (
        <div class="group relative bg-gray-50 dark:bg-dark-bg-secondary border border-gray-200 dark:border-dark-border rounded-2xl p-6 sm:p-8 transition-all duration-300 hover:border-primary/50 dark:hover:border-accent/50 hover:bg-gray-100 dark:hover:bg-dark-bg-secondary hover:-translate-y-1">
          <!-- Icono container -->
          <div class="flex items-center justify-center w-16 h-16 rounded-full bg-primary/10 dark:bg-accent/20 border border-primary/20 dark:border-accent/30 mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:bg-primary/20 dark:group-hover:bg-accent/30">
            <razon.icono class="w-8 h-8 text-primary dark:text-accent" />
          </div>

          <!-- Titulo -->
          <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 dark:text-dark-text mb-3">
            {razon.titulo}
          </h3>

          <!-- Descripcion -->
          <p class="text-base text-gray-500 dark:text-dark-text-secondary leading-relaxed">
            {razon.descripcion}
          </p>

          <!-- Hover effect line -->
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-primary dark:bg-accent transition-all duration-300 group-hover:w-3/4"></div>
        </div>
      ))}
    </div>
  </Container>
</section>