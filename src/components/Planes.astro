---

<section id="planes" class="relative py-20 lg:py-32 bg-white dark:bg-dark-bg">
  <Container>
    <!-- Section header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-dark-text mb-4">
        Nuestros <span class="text-primary dark:text-accent">planes</span>
      </h2>
      <p class="text-lg text-gray-500 dark:text-dark-text-secondary max-w-2xl mx-auto">
        Planes diseñados para cada necesidad. Encontrá el perfecto para tu negocio
      </p>
    </div>

    <!-- Tabs para cambiar entre tipos de planes -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <button
        class="tab-btn active px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 bg-primary dark:bg-accent text-white"
        data-tab="desarrollo"
      >
        Desarrollo Web
      </button>
      <button
        class="tab-btn px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 bg-gray-100 dark:bg-dark-bg-secondary text-gray-600 dark:text-dark-text-secondary hover:bg-gray-200 dark:hover:bg-slate-700"
        data-tab="mantenimiento"
      >
        Mantenimiento
      </button>
      <button
        class="tab-btn px-6 py-3 rounded-full text-sm font-medium transition-all duration-300 bg-gray-100 dark:bg-dark-bg-secondary text-gray-600 dark:text-dark-text-secondary hover:bg-gray-200 dark:hover:bg-slate-700"
        data-tab="extras"
      >
        Extras
      </button>
    </div>

    <!-- Tab: Desarrollo Web -->
    <div class="tab-content active" id="desarrollo">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {planesWeb.map((plan) => (
          <div class={`group relative bg-white dark:bg-dark-bg-secondary border-2 rounded-2xl p-6 transition-all duration-300 hover:shadow-xl ${plan.populares ? 'border-primary dark:border-accent hover:border-primary dark:hover:border-accent' : 'border-gray-200 dark:border-dark-border hover:border-primary/50 dark:hover:border-accent/50'}`}>
            <!-- Badge de popular -->
            {plan.populares && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center gap-1 px-4 py-1 rounded-full text-xs font-semibold bg-primary dark:bg-accent text-white">
                  <Icons.IconStar class="w-3 h-3" />
                  Más popular
                </span>
              </div>
            )}

            <!-- Icono y nombre -->
            <div class="flex items-center gap-3 mb-4">
              <div class={`p-3 rounded-xl ${plan.populares ? 'bg-primary/10 dark:bg-accent/10 text-primary dark:text-accent' : 'bg-gray-100 dark:bg-dark-bg text-gray-600 dark:text-dark-text-secondary'}`}>
                <plan.icono class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold text-gray-900 dark:text-dark-text">
                {plan.nombre}
              </h3>
            </div>

            <!-- Precio -->
            <div class="mb-4">
              <span class="text-3xl font-bold text-primary dark:text-accent">{plan.precio}</span>
            </div>

            <!-- Descripción -->
            <p class="text-sm text-gray-500 dark:text-dark-text-secondary mb-6">
              {plan.descripcion}
            </p>

            <!-- Incluye -->
            <div class="mb-4">
<h4 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-2">
                  <Icons.IconCheck class="w-4 h-4 text-green-500" />
                  Incluye:
                </h4>
              <ul class="space-y-1">
                {plan.incluye.map((item) => (
                  <li class="text-sm text-gray-600 dark:text-dark-text-secondary flex items-start gap-2">
                    <Icons.IconCheck class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- No incluye -->
            {plan.noIncluye && plan.noIncluye.length > 0 && (
              <div class="mb-4">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-2">
<Icons.IconX class="w-4 h-4 text-red-400" />
                  No incluye:
                </h4>
                <ul class="space-y-1">
                  {plan.noIncluye.map((item) => (
                    <li class="text-sm text-gray-400 dark:text-gray-500 flex items-start gap-2">
<Icons.IconX class="w-4 h-4 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Nota -->
            {plan.note && (
              <p class="text-xs text-gray-400 dark:text-gray-500 italic mt-4 pt-4 border-t border-gray-100 dark:border-dark-border">
                {plan.note}
              </p>
            )}

            <!-- Ejemplos de páginas -->
            {plan.ejemplos && (
              <div class="mt-4 pt-4 border-t border-gray-100 dark:border-dark-border">
                <p class="text-xs text-gray-500 dark:text-dark-text-secondary mb-2">Ejemplos de páginas:</p>
                <div class="flex flex-wrap gap-2">
                  {plan.ejemplos.map((ej) => (
                    <span class="px-2 py-1 text-xs rounded-md bg-gray-100 dark:bg-dark-bg text-gray-600 dark:text-dark-text-secondary">
                      {ej}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Tab: Mantenimiento -->
    <div class="tab-content hidden" id="mantenimiento">
      <!-- Mantenimiento Básico -->
      <div class="mb-12">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-3">
          <Icons.IconTool class="w-7 h-7 text-primary dark:text-accent" />
          Planes de Mantenimiento
        </h3>
        <p class="text-gray-500 dark:text-dark-text-secondary mb-8">
          Mantenimiento para sitios básicos desarrollados por nosotros
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
          {mantenimientoBasico.map((plan) => (
            <div class="group relative bg-white dark:bg-dark-bg-secondary border-2 border-gray-200 dark:border-dark-border rounded-2xl p-6 transition-all duration-300 hover:border-primary/50 dark:hover:border-accent/50 hover:shadow-xl">
              <h3 class="text-xl font-bold text-gray-900 dark:text-dark-text mb-2">
                {plan.nombre}
              </h3>
              <span class="text-3xl font-bold text-primary dark:text-accent">{plan.precio}</span>
              <p class="text-sm text-gray-500 dark:text-dark-text-secondary mt-2 mb-4">
                {plan.descripcion}
              </p>

              <div class="mb-4">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-2">
                  <Icons.IconCheck class="w-4 h-4 text-green-500" />
                  Incluye:
                </h4>
                <ul class="space-y-1">
                  {plan.incluye.map((item) => (
                    <li class="text-sm text-gray-600 dark:text-dark-text-secondary flex items-start gap-2">
                      <Icons.IconCheck class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              {plan.noIncluye && plan.noIncluye.length > 0 && (
                <div class="mb-4">
<h4 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-2">
                  <Icons.IconX class="w-4 h-4 text-red-400" />
                    No incluye:
                  </h4>
                  <ul class="space-y-1">
                    {plan.noIncluye.map((item) => (
<li class="text-sm text-gray-400 dark:text-gray-500 flex items-start gap-2">
                        <Icons.IconX class="w-4 h-4 text-gray-300 dark:text-gray-600 mt-0.5 flex-shrink-0" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Mantenimiento Avanzado -->
      <div>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-3">
          <Icons.IconSparkles class="w-7 h-7 text-primary dark:text-accent" />
          Mantenimiento para Sitios Avanzados
        </h3>
        <p class="text-gray-500 dark:text-dark-text-secondary mb-8">
          Planes de mantenimiento para tiendas online, sistemas de turnos y sitios más complejos
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {mantenimientoAvanzado.map((plan) => (
            <div class="group relative bg-gradient-to-br from-primary/5 to-accent/5 dark:from-accent/10 dark:to-primary/10 border-2 border-primary/20 dark:border-accent/20 rounded-2xl p-6 transition-all duration-300 hover:border-primary dark:hover:border-accent hover:shadow-xl">
              <h3 class="text-xl font-bold text-gray-900 dark:text-dark-text mb-2">
                {plan.nombre}
              </h3>
              <span class="text-3xl font-bold text-primary dark:text-accent">{plan.precio}</span>

              <div class="mt-4">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-dark-text mb-2 flex items-center gap-2">
                  <Icons.IconCheck class="w-4 h-4 text-green-500" />
                  Incluye:
                </h4>
                <ul class="space-y-1">
                  {plan.incluye.map((item) => (
                    <li class="text-sm text-gray-600 dark:text-dark-text-secondary flex items-start gap-2">
                      <Icons.IconCheck class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Tab: Extras -->
    <div class="tab-content hidden" id="extras">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-dark-bg-secondary border-2 border-gray-200 dark:border-dark-border rounded-2xl p-8">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-dark-text mb-6 text-center">
            Servicios Extra
          </h3>
          <div class="space-y-4">
            {extras.map((extra) => (
              <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-dark-bg rounded-xl">
                <span class="text-gray-900 dark:text-dark-text font-medium">{extra.servicio}</span>
                <span class="text-primary dark:text-accent font-bold">{extra.precio}</span>
              </div>
            ))}
          </div>
          <p class="text-sm text-gray-500 dark:text-dark-text-secondary text-center mt-6">
            ¿Necesitas algo que no está en la lista? Contáctanos y te cotizamos
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');

      // Update buttons
      tabBtns.forEach(b => {
        b.classList.remove('bg-primary', 'dark:bg-accent', 'text-white');
        b.classList.add('bg-gray-100', 'dark:bg-dark-bg-secondary', 'text-gray-600', 'dark:text-dark-text-secondary');
      });
      btn.classList.remove('bg-gray-100', 'dark:bg-dark-bg-secondary', 'text-gray-600', 'dark:text-dark-text-secondary');
      btn.classList.add('bg-primary', 'dark:bg-accent', 'text-white');

      // Update content
      tabContents.forEach(content => {
        content.classList.add('hidden');
        content.classList.remove('active');
      });
      const activeContent = document.getElementById(tabId);
      if (activeContent) {
        activeContent.classList.remove('hidden');
        activeContent.classList.add('active');
      }
    });
  });
</script>

<style>
  .tab-content.active {
    display: block;
  }
  .tab-content.hidden {
    display: none;
  }
</style>